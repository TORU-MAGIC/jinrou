// ========== P2P ENGINE (PeerJS サーバーレスオンライン) ==========
const P2PEngine = (() => {
  const CPU_NAMES = ['ハル','ユキ','アオイ','カイ','リン','ソラ','ナギ','ツバキ','コウ','アン','ミオ','レン','サキ','ジン','ノア'];
  let peer = null;
  let guestConn = null;   // guest→host接続
  let hostConns = {};     // host: { connId: DataConnection }
  let connNames = {};     // host: { connId: playerName }
  let R = {};
  let isHost = false;

  let _timers = [];
  function emitLocal(msg) { const id = setTimeout(() => handleServer(msg), 0); _timers.push(id); return id; }
  function later(ms, fn)  { const id = setTimeout(fn, ms); _timers.push(id); return id; }
  function resetTimers()  {
    _timers.forEach(clearTimeout); _timers = [];
    if (R && R._humanTurnTimer) { clearTimeout(R._humanTurnTimer); R._humanTurnTimer = null; }
    if (R && R._discFallback)   { clearTimeout(R._discFallback);   R._discFallback = null; }
  }
  function rand(a)        { return a[Math.floor(Math.random()*a.length)]; }
  function shuffle(a)     { a=[...a]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }
  function alive()        { return R.players.filter(p=>p.alive); }
  function byName(n)      { return R.players.find(p=>p.name===n); }
  function topAcc(pls)    { let max=0,best=null; pls.forEach(p=>{const c=R.accuCount[p.name]||0;if(c>max){max=c;best=p;}}); return best; }

  // ホストから全員にブロードキャスト
  function broadcast(msg) {
    const json = JSON.stringify(msg);
    Object.values(hostConns).forEach(c => { try { c.send(json); } catch(e){} });
    emitLocal(msg);
  }
  // ホストから特定プレイヤーのみに送信
  function sendTo(playerName, msg) {
    const json = JSON.stringify(msg);
    const cid = Object.keys(connNames).find(k=>connNames[k]===playerName);
    if (cid && hostConns[cid]) { try { hostConns[cid].send(json); } catch(e){} }
    if (playerName === R.hostName) emitLocal(msg);
  }
  function sendToWolves(msg) {
    R.players.filter(p=>p.role==='WEREWOLF').forEach(p=>sendTo(p.name, msg));
  }

  // ── ホスト: 部屋作成 ──────────────────────────────────
  function createRoom(hostName, onCode) {
    isHost = true;
    R.hostName = hostName;
    R.pendingPlayers = [{ name: hostName, isCpu: false }];
    const code = String(Math.floor(10000 + Math.random() * 89999));
    const pid  = 'WLF' + code;
    peer = new Peer(pid, { debug: 0 });
    peer.on('open', id => {
      const roomCode = id.startsWith('WLF') ? id.slice(3) : id.slice(0,5).toUpperCase();
      onCode(roomCode);
    });
    peer.on('connection', conn => {
      conn.on('open', () => {
        hostConns[conn.peer] = conn;
        conn.on('data', raw => {
          try { handleGuestMsg(conn.peer, JSON.parse(raw)); } catch(e){}
        });
        conn.on('close', () => {
          const name = connNames[conn.peer];
          delete hostConns[conn.peer];
          delete connNames[conn.peer];
          if (name && R.pendingPlayers) {
            R.pendingPlayers = R.pendingPlayers.filter(p=>p.name!==name);
            O.players = O.players.filter(p=>p.name!==name);
            broadcast({ type:'player_left', players: O.players });
          }
        });
      });
    });
    peer.on('error', err => {
      if (err.type === 'unavailable-id') { peer.destroy(); createRoom(hostName, onCode); }
      else alert('P2P接続エラー: ' + err.message);
    });
  }

  // ── ゲスト: 部屋参加 ─────────────────────────────────
  function joinRoom(guestName, code, onJoined, onError) {
    isHost = false;
    peer = new Peer({ debug: 0 });
    peer.on('open', () => {
      guestConn = peer.connect('WLF' + code, { reliable: true });
      guestConn.on('open', () => {
        guestConn.send(JSON.stringify({ type:'join_room', name: guestName }));
        guestConn.on('data', raw => {
          try { handleServer(JSON.parse(raw)); } catch(e){}
        });
        onJoined();
      });
      guestConn.on('error', onError);
    });
    peer.on('error', err => onError(err));
  }

  // ── ゲストからのメッセージをホストが処理 ─────────────
  function handleGuestMsg(connId, data) {
    // '__host__' はホスト自身が送ったメッセージ
    const pname = (connId === '__host__') ? R.hostName : connNames[connId];
    switch (data.type) {
      case 'join_room': {
        const name = (data.name||'ゲスト').trim();
        connNames[connId] = name;
        R.pendingPlayers = R.pendingPlayers||[];
        if (!R.pendingPlayers.find(p=>p.name===name))
          R.pendingPlayers.push({ name, isCpu: false });
        O.players = O.players || [];
        if (!O.players.find(p=>p.name===name))
          O.players.push({ pid: O.players.length, name });
        broadcast({ type:'player_joined', players: O.players });
        break;
      }
      case 'set_cpu_count':
        O.cpuCount = data.count;
        broadcast({ type:'cpu_count_updated', count: data.count });
        break;
      case 'start_game':
        startGame();
        break;
      case 'start_night':
        if (R.players[0]?.role==='WEREWOLF') startWolfChat(); else startNight();
        break;
      case 'wolf_chat_done':
        later(400, startNight);
        break;
      case 'wolf_chat_msg':
        if (pname) sendToWolves({ type:'wolf_chat_msg', name:pname, text:data.text });
        break;
      case 'night_action':
        if (pname) handleNightAction(pname, data);
        break;
      case 'disc_message':
        if (pname) handleDiscMsg(pname, data.text);
        break;
      case 'vote':
        if (pname) handleVote(pname, data.target);
        break;
      case 'music_ended':
        if (isHost && R.phase === 'discuss') { R.phase = 'voting'; later(300, startVote); }
        break;
      case 'vote_ready':
        if (!isHost || R.phase !== 'discuss') break;
        if (!R.voteReadySet) R.voteReadySet = new Set();
        R.voteReadySet.add(pname);
        broadcast({ type:'vote_ready_upd', readyNames:[...R.voteReadySet] });
        _checkVoteReadyP2P();
        break;
      case 'next_night':
        later(300, () => alive().some(p=>p.role==='WEREWOLF'&&!p.isCpu) ? startWolfChat() : startNight());
        break;
    }
  }

  // ── ゲームスタート ───────────────────────────────────
  function startGame() {
    resetTimers(); // 前ゲームのタイマーを掃除
    const humanPlayers = R.pendingPlayers || [{ name: R.hostName, isCpu: false }];
    const cpuCount = O.cpuCount || 0;
    const cpuPool = shuffle(CPU_NAMES.filter(n=>!humanPlayers.find(p=>p.name===n)));
    const allPlayers = [...humanPlayers];
    for (let i=0; i<cpuCount; i++)
      allPlayers.push({ name: cpuPool[i]||`CPU${i+1}`, isCpu: true });

    const total = allPlayers.length;
    const roles = shuffle([...(CONFIGS[total]||CONFIGS[6])]);
    R = {
      ...R,
      players: allPlayers.map((p,i)=>({...p, role:roles[i], alive:true})),
      day:0, phase:'role',
      wolfTarget:null, doctorTarget:null,
      lastDoctorTarget:null, lastExecuted:null, lastExecutedRole:null,
      humanActionDone:{}, cpuNightDone:false,
      humanWolfChoice:null, resolveDone:false,
      discMsgs:[], discOrder:[], discIdx:0, discRound:1,
      waitingForHuman: null, _discFallback: null,
      votes:{}, humanVotedSet:new Set(), tallyDone:false,
      accuCount:{}, seerKnown:{}, log:[],
    };
    BRAIN.initR(R); // BRAIN メモリ初期化
    // CPUにパーソナリティをランダム付与
    R.players.forEach(p => { if (p.isCpu) p.personality = rand(CPU_PERSONALITIES); });

    // 各プレイヤーに役職送信
    R.players.forEach(player => {
      if (player.isCpu) return;
      const wolves = R.players.filter(p=>p.role==='WEREWOLF');
      const partners = player.role==='WEREWOLF' ? wolves.filter(p=>p!==player).map(p=>p.name) : [];
      const isH = player.name === R.hostName;
      const msg = {
        type:'game_started', role:player.role, wolf_partners:partners,
        players:R.players.map((p,i)=>({pid:i,name:p.name})), is_host:isH,
      };
      sendTo(player.name, msg);
    });
  }

  // ── 夜 ──────────────────────────────────────────────
  function startWolfChat() {
    R.phase='wolf_chat';
    BRAIN.initR(R);
    const wolves = alive().filter(p=>p.role==='WEREWOLF');
    sendToWolves({ type:'wolf_chat_start', wolf_names:wolves.map(p=>p.name) });
    const cpuWolves = wolves.filter(p=>p.isCpu);
    const vill = alive().filter(p=>p.role!=='WEREWOLF');
    if (cpuWolves.length && vill.length) {
      const tgt = BRAIN.wolfNightTarget(R) || topAcc(vill) || rand(vill);
      let t = 1000;
      cpuWolves.forEach(w => {
        later(t, ()=>sendToWolves({type:'wolf_chat_msg',name:w.name,text:tplFill(rand(TPL.wolf_night),tgt.name)}));
        t += 1400 + Math.floor(Math.random()*600);
      });
    }
  }

  function startNight() {
    R.day++; R.phase='night';
    R.wolfTarget=null; R.doctorTarget=null;
    R.humanActionDone={}; R.cpuNightDone=false;
    R.humanWolfChoice=null; R.resolveDone=false;
    const al = alive();
    broadcast({ type:'night_start', day:R.day });
    // 霊媒師に処刑情報を送信（処刑があった場合）
    if (R.lastExecuted) {
      const mediums = al.filter(p=>!p.isCpu&&p.role==='MEDIUM');
      mediums.forEach(m=>sendTo(m.name,{type:'medium_reveal',target:R.lastExecuted,role:R.lastExecutedRole}));
    }
    // 各役職プレイヤーにアクション要求
    al.forEach(p => {
      if (p.isCpu) return;
      const others = al.filter(x=>x!==p);
      // 初日から全役職が行動可能
      if (p.role==='WEREWOLF') {
        const wnames = al.filter(x=>x.role==='WEREWOLF').map(x=>x.name);
        sendTo(p.name,{type:'action_needed',action:'wolf',targets:others.filter(x=>x.role!=='WEREWOLF').map(x=>({name:x.name})),wolf_names:wnames});
      } else if (p.role==='SEER') {
        sendTo(p.name,{type:'action_needed',action:'seer',targets:others.map(x=>({name:x.name}))});
      } else if (p.role==='DOCTOR') {
        const docTargets = al.filter(x=>x.name!==R.lastDoctorTarget);
        sendTo(p.name,{type:'action_needed',action:'doctor',targets:docTargets.map(x=>({name:x.name})),last_protected:R.lastDoctorTarget});
      } else {
        R.humanActionDone[p.name] = true;
      }
    });
    later(1600, () => {
      doCpuNight(); R.cpuNightDone=true;
      checkNightDone();
    });
  }

  function doCpuNight() {
    BRAIN.initR(R);
    const al = alive();
    // 占い師CPU（毎夜）: 疑い度の高い未占い者を優先
    const cpuSeer = al.find(p=>p.isCpu&&p.role==='SEER');
    if (cpuSeer) {
      const unk = al.filter(p=>p!==cpuSeer&&R.seerKnown[p.name]===undefined);
      let t = null;
      if (unk.length) {
        let best=-1,b=null;
        unk.forEach(p=>{const s=(R.suspicion?.[p.name]||0); if(s>best){best=s;b=p;}});
        t = b || rand(unk);
      } else { t = rand(al.filter(p=>p!==cpuSeer)); }
      if (t) R.seerKnown[t.name]=(t.role==='WEREWOLF');
    }
    // 人狼CPU標的（BRAIN 戦略）
    const cpuWolves = al.filter(p=>p.isCpu&&p.role==='WEREWOLF');
    const vill = al.filter(p=>p.role!=='WEREWOLF');
    if (cpuWolves.length && vill.length) {
      const tgt = BRAIN.wolfNightTarget(R) || topAcc(vill) || rand(vill);
      if (tgt) R.wolfTarget = tgt.name;
    }
    // 騎士CPU: CO占い師>霊媒師>かばわれてる人 を護衛
    const cpuDoc = al.find(p=>p.isCpu&&p.role==='DOCTOR');
    if (cpuDoc) {
      const baseCands = (vill.length?vill:al).filter(p=>p.name!==R.lastDoctorTarget && p.name!==cpuDoc.name);
      let t = null;
      const trueSeerCO = (R.seerCOs||[]).find(c=>{const p=R.players.find(x=>x.name===c.name); return p&&p.alive&&p.role==='SEER';});
      if (trueSeerCO) t = baseCands.find(p=>p.name===trueSeerCO.name);
      if (!t) {
        const trueMedCO = (R.mediumCOs||[]).find(c=>{const p=R.players.find(x=>x.name===c.name); return p&&p.alive&&p.role==='MEDIUM';});
        if (trueMedCO) t = baseCands.find(p=>p.name===trueMedCO.name);
      }
      if (!t && baseCands.length) {
        let best=-Infinity,b=null;
        baseCands.forEach(p=>{const sc=(R.coverCount?.[p.name]||0)-(R.suspicion?.[p.name]||0)*0.5; if(sc>best){best=sc;b=p;}});
        t = b || rand(baseCands);
      }
      if (t) R.doctorTarget = t.name;
    }
  }

  function handleNightAction(pname, data) {
    const player = byName(pname);
    if (!player) return;
    if (player.role==='WEREWOLF') {
      R.humanWolfChoice=data.target;
      sendToWolves({type:'wolf_chosen',target:data.target});
      sendTo(pname,{type:'action_ack'});
    } else if (player.role==='SEER') {
      const tgt=byName(data.target);
      const iw=tgt?tgt.role==='WEREWOLF':false;
      R.seerKnown[data.target]=iw;
      sendTo(pname,{type:'seer_result',target:data.target,is_wolf:iw});
    } else if (player.role==='DOCTOR') {
      R.doctorTarget=data.target;
      sendTo(pname,{type:'action_ack'});
    }
    R.humanActionDone[pname]=true;
    checkNightDone();
  }

  function checkNightDone() {
    const al=alive();
    const humans=al.filter(p=>!p.isCpu);
    const allDone=humans.every(p=>R.humanActionDone[p.name]);
    if (allDone&&R.cpuNightDone) later(700,resolveNight);
  }

  function resolveNight() {
    if (R.resolveDone) return; R.resolveDone=true;
    const wt=R.humanWolfChoice||R.wolfTarget;
    const dt=R.doctorTarget;
    // 騎士護衛対象を次夜用に記録（連続護衛禁止）
    R.lastDoctorTarget=dt;
    R.wolfTarget=null; R.doctorTarget=null; R.humanWolfChoice=null;
    let victim=null;
    if (wt&&wt!==dt) {
        const v=byName(wt);
        if(v&&v.alive){
          v.alive=false; victim=v;
          R.log.push(`第${R.day}夜:${wt}が人狼に倒された`);
          // 猫又ルール
          if (v.role==='NEKOMATA') {
            const wolves=alive().filter(x=>x.role==='WEREWOLF');
            if(wolves.length){const dragged=rand(wolves);dragged.alive=false;R.log.push(`第${R.day}夜:猫又道連れで${dragged.name}も倒れた`);}
          }
        }
    } else if (wt&&wt===dt) R.log.push(`第${R.day}夜:騎士が${wt}を護衛した`);
    const win=checkWinP2P();
    if (win) { doGameOver(win,victim); return; }
    later(400,()=>startDiscuss(victim));
  }

  // ── 議論 ────────────────────────────────────────────
  function _checkVoteReadyP2P() {
    if (R.phase !== 'discuss') return;
    if (alive().every(p => R.voteReadySet.has(p.name))) {
      if (R._discFallback) { clearTimeout(R._discFallback); R._discFallback = null; }
      broadcast({ type:'vote_ready_all' });
      later(1900, () => { if (R.phase === 'discuss') { R.phase='voting'; startVote(); } });
    }
  }

  function startDiscuss(victim) {
    R.phase='discuss'; R.discRound=1; R.discMsgs=[];
    R.waitingForHuman=null;
    R.voteReadySet = new Set();
    const elim=victim?{name:victim.name}:null;
    const al=alive();
    const song = _pickSong();
    const songStarted = Date.now() + 650;
    if (R._discFallback) clearTimeout(R._discFallback);
    R._discFallback = setTimeout(()=>{ if(R.phase==='discuss'){R.phase='voting';startVote();} }, 5*60*1000);
    broadcast({type:'discuss_start',round:1,total_rounds:2,eliminated:elim,alive:al.map(p=>({name:p.name})),song,songStarted});
    R.discOrder=shuffle([...al]);
    R.discIdx=0;
    later(600,advanceDisc);
  }

  function advanceDisc() {
    if (R.phase !== 'discuss') return;
    if (R.discIdx >= R.discOrder.length) {
      if (R.discRound < 2) {
        R.discRound = 2; R.discIdx = 0;
        broadcast({ type:'disc_new_round', round:2 });
        later(700, advanceDisc);
      } else {
        // 2ラウンド完了: 全CPUを自動レディ
        alive().filter(p=>p.isCpu).forEach((p,i) => {
          later(600 + i*350, () => {
            if (R.phase !== 'discuss') return;
            R.voteReadySet.add(p.name);
            broadcast({ type:'vote_ready_upd', readyNames:[...R.voteReadySet] });
            _checkVoteReadyP2P();
          });
        });
      }
      return;
    }
    const player = R.discOrder[R.discIdx];
    if (!player || !player.alive) { R.discIdx++; later(300, advanceDisc); return; }
    if (player.isCpu) {
      broadcast({ type:'disc_turn', name:player.name });
      later(typingDelay(player.personality), () => {
        if (R.phase !== 'discuss') return;
        const txt = BRAIN.speak(R, player);
        BRAIN.parseClaim(R, player.name, txt);
        R.discMsgs.push({ name:player.name, text:txt });
        broadcast({ type:'disc_message', name:player.name, text:txt });
        R.discIdx++;
        later(readPause(txt), advanceDisc); // テキスト長に比例した読む時間を確保
      });
    } else {
      broadcast({ type:'disc_turn', name:player.name });
      sendTo(player.name, { type:'your_disc_turn' });
      R.waitingForHuman = player.name;
      R.discIdx++;
      // 30秒経っても発言しなければ自動進行（音楽なし環境対策）
      if (R._humanTurnTimer) clearTimeout(R._humanTurnTimer);
      R._humanTurnTimer = setTimeout(() => {
        if (R.phase !== 'discuss' || R.waitingForHuman !== player.name) return;
        R.waitingForHuman = null;
        later(200, advanceDisc);
      }, 30 * 1000);
    }
  }

  function handleDiscMsg(pname, text) {
    if (R.phase !== 'discuss') return;
    BRAIN.parseClaim(R, pname, text); // 人間発言から CO・かばう・疑うを学習
    R.discMsgs.push({ name:pname, text });
    broadcast({ type:'disc_message', name:pname, text });
    // 順番が来ていたプレイヤーの発言なら次へ進む（フリー入力はターン外でも発言可）
    if (R.waitingForHuman === pname) {
      R.waitingForHuman = null;
      if (R._humanTurnTimer) { clearTimeout(R._humanTurnTimer); R._humanTurnTimer = null; }
      later(600, advanceDisc);
    }
  }

  // ── 投票 ─────────────────────────────────────────────
  function startVote() {
    R.phase='vote'; R.votes={}; R.humanVotedSet=new Set(); R.tallyDone=false;
    if (R._discFallback) { clearTimeout(R._discFallback); R._discFallback = null; } // 議論フォールバックを停止
    const al=alive();
    // 死亡プレイヤーは投票不要
    al.filter(p=>!p.isCpu).forEach(p=>{ /* 生きている人間のみ投票 */ });
    broadcast({type:'vote_start',alive:al.map(p=>({name:p.name}))});
    const cpus=al.filter(p=>p.isCpu);
    cpus.forEach((cpu,i)=>later(900+i*600,()=>{
      const tgt=BRAIN.vote(R, cpu);
      if (tgt) R.votes[cpu.name]=tgt.name;
      const humansVoted=R.humanVotedSet.size;
      const humanCount=al.filter(p=>!p.isCpu).length;
      broadcast({type:'vote_progress',done:Object.keys(R.votes).length+humansVoted,total:al.length});
      if (humansVoted>=humanCount&&Object.keys(R.votes).length>=cpus.length) later(400,tallyVotes);
    }));
    if (!cpus.length && al.filter(p=>!p.isCpu).length===0) later(500,tallyVotes);
  }

  function handleVote(pname, target) {
    R.votes[pname]=target;
    R.humanVotedSet.add(pname);
    const al=alive();
    broadcast({type:'vote_progress',done:Object.keys(R.votes).length,total:al.length});
    const humansAlive=al.filter(p=>!p.isCpu);
    if (R.humanVotedSet.size>=humansAlive.length&&Object.keys(R.votes).length>=al.filter(p=>p.isCpu).length)
      later(500,tallyVotes);
  }

  function cpuVoteTarget(cpu) {
    const al=alive(), others=al.filter(p=>p.name!==cpu.name);
    if (!others.length) return null;
    if (cpu.role==='WEREWOLF'||cpu.role==='MADMAN') {
      const vill=others.filter(p=>p.role!=='WEREWOLF');
      return vill.length?(topAcc(vill)||rand(vill)):rand(others);
    }
    const wolves=others.filter(p=>p.role==='WEREWOLF');
    if (wolves.length&&Math.random()<0.5) return topAcc(wolves)||rand(wolves);
    return topAcc(others)||rand(others);
  }

  function tallyVotes() {
    if (R.tallyDone) return; R.tallyDone=true;
    const tally={};
    Object.values(R.votes).forEach(t=>tally[t]=(tally[t]||0)+1);
    const maxV=Math.max(...Object.values(tally));
    const top=Object.keys(tally).filter(n=>tally[n]===maxV);
    const executed=top[Math.floor(Math.random()*top.length)];
    const execP=byName(executed);
    if (execP) execP.alive=false;
    R.log.push(`第${R.day}日:${executed}が処刑された`);
    // 霊媒師用に処刑情報を保存
    R.lastExecuted=executed; R.lastExecutedRole=execP?.role;
    // 猫又ルール: 処刑時にランダムな生存者を道連れ
    let nekomataVictim=null;
    if (execP?.role==='NEKOMATA') {
      const bystanders=alive();
      if(bystanders.length){nekomataVictim=rand(bystanders);nekomataVictim.alive=false;R.log.push(`第${R.day}日:猫又道連れで${nekomataVictim.name}も倒れた`);}
    }
    const win=checkWinP2P();
    broadcast({
      type:'vote_result', executed, executed_role:execP?.role, tally,
      nekomata_victim:nekomataVictim?.name,
      winner:win,
      players:win?R.players.map(p=>({name:p.name,role:p.role,alive:p.alive})):null,
      log:win?R.log:null,
    });
    // 霊媒師（生存人間）に個別通知
    const mediums=alive().filter(p=>!p.isCpu&&p.role==='MEDIUM');
    mediums.forEach(m=>sendTo(m.name,{type:'medium_reveal',target:executed,role:execP?.role}));
  }

  function checkWinP2P() {
    const al=alive();
    const w=al.filter(p=>p.role==='WEREWOLF').length;
    const v=al.length-w;
    if (!w) return 'village';
    if (w>=v) return 'wolf';
    return null;
  }

  function doGameOver(winner, victim) {
    broadcast({
      type:'game_over', winner,
      players:R.players.map(p=>({name:p.name,role:p.role,alive:p.alive})),
      log:R.log,
      eliminated:victim?{name:victim.name,role:victim.role}:null,
    });
  }

  function cpuTpl(cpu) {
    const al=alive(), others=al.filter(p=>p.name!==cpu.name);
    const wasAcc=(R.accuCount[cpu.name]||0)>0;
    const pers = cpu.personality || 'balanced';

    // ── 人狼・狂人 ──
    if (cpu.role==='WEREWOLF'||cpu.role==='MADMAN') {
      if (wasAcc) return rand(TPL.defend);
      const vill=others.filter(p=>p.role!=='WEREWOLF');
      if (pers==='wolf_smart') {
        if (Math.random()<0.12) return rand(TPL.defend);
        if (vill.length&&Math.random()<0.78) {
          const t=topAcc(vill)||rand(vill);
          R.accuCount[t.name]=(R.accuCount[t.name]||0)+1;
          return tplFill(rand(TPL.accuse),t.name);
        }
        return rand(TPL.neutral);
      }
      const acProb = pers==='aggressive' ? 0.82 : 0.65;
      if (vill.length&&Math.random()<acProb) {
        const t=topAcc(vill)||rand(vill);
        R.accuCount[t.name]=(R.accuCount[t.name]||0)+1;
        return tplFill(rand(TPL.accuse),t.name);
      }
      return rand(TPL.neutral);
    }

    // ── 占い師 ──
    if (cpu.role==='SEER') {
      const known=Object.entries(R.seerKnown);
      const revProb = pers==='quick_co' ? 0.88 : pers==='secretive' ? 0.20 : 0.55;
      if (known.length&&Math.random()<revProb) {
        const [nm,iw]=rand(known);
        if(iw) R.accuCount[nm]=(R.accuCount[nm]||0)+2;
        return tplFill(rand(iw?TPL.seer_wolf:TPL.seer_safe),nm);
      }
      if (pers==='quick_co' && R.discRound===1 && Math.random()<0.65)
        return rand(['占い師としてCOします 🔮','私が占い師です。情報を集めています 🔮','占い師として名乗り出ます 🔮']);
    }

    // ── 騎士 ──
    if (cpu.role==='DOCTOR') {
      const coProb = pers==='quick_co' ? 0.50 : pers==='secretive' ? 0.04 : 0.12;
      if (Math.random()<coProb)
        return rand(['騎士としてCOします 💊','私は騎士です。誰かを守っています 💊','騎士COします。護衛中です 💊']);
    }

    if (wasAcc) return rand(TPL.defend);
    const accuseProb = pers==='aggressive' ? 0.70 : pers==='secretive' ? 0.10 : pers==='quick_co' ? 0.35 : 0.38;
    if (others.length&&Math.random()<accuseProb) {
      const t=topAcc(others)||rand(others);
      R.accuCount[t.name]=(R.accuCount[t.name]||0)+1;
      return tplFill(rand(TPL.accuse),t.name);
    }
    if (pers==='secretive') return rand(TPL.neutral);
    if (pers==='aggressive') return rand(TPL.pressure);
    return rand([...TPL.neutral,...TPL.question].slice(0,14));
  }

  // ── 外部公開 ─────────────────────────────────────────
  function wsSendP2P(msg) {
    if (isHost) { handleGuestMsg('__host__', msg); }
    else if (guestConn&&guestConn.open) { guestConn.send(JSON.stringify(msg)); }
  }

  function destroy() {
    resetTimers(); // 残留タイマーを停止してから破棄
    if (peer) { try{peer.destroy();}catch(e){} peer=null; }
    hostConns={}; connNames={}; guestConn=null; isHost=false; R={};
  }

  return { createRoom, joinRoom, wsSendP2P, startGame, destroy, resetTimers };
})();

// ========== ONLINE STATE ==========
// mode は最下部で 'opening' として初期化
let O = {};

function initOnline() {
  O = {
    ws: null, pid: null, isHost: false,
    roomCode: null, playerName: '', serverAddr: 'localhost:8765',
    setupSub: 'choose',
    players: [], cpuCount: 0,
    myRole: null, wolfPartners: [],
    phase: 'setup',
    day: 0, alive: [], eliminatedLastNight: null,
    nightActionNeeded: null, nightActionDone: false,
    seerResult: null, wolfChosen: null,
    // Wolf chat
    wolfChatMsgs: [], wolfChatReady: false, wolfPartnerNames: [],
    // Discussion
    discMsgs: [], discRound: 1, discTotalRounds: 2,
    currentSpeaker: null, isMyDiscTurn: false,
    tplStep: null,   // null|'cat'|'tgt_accuse'|'tgt_agree'|'tgt_seer'|'msg_neutral'|'msg_accuse'|'msg_defend'|'msg_agree'|'msg_seer'
    tplTarget: null,
    tplSeerType: null, // 'wolf'|'safe'
    // Vote
    voteSubmitted: false, voteDone: 0, voteTotal: 0,
    voteResult: null, winner: null,

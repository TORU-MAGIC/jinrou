// ========== AUDIO SYSTEM ==========
const SONGS = ['人狼ゲーム1.mp3','人狼ゲーム2.mp3','人狼ゲーム3.mp3','人狼ゲーム4.mp3','人狼ゲーム5.mp3','人狼ゲーム6.mp3','月下の投票１','オオカミの夜１.mp3'];
let bgmAudio = null;
let _usedSongs = [];
let _audioUnlocked = false;
let _primedPool = {}; // iOS対策: ユーザータップ時に全曲プライミング
let _bgmMuted = false; // 端末ごとのミュート（同室複数スマホ対策）
let _openingAudio = null; // オープニング音楽の直接参照（bgmAudio が .catch() で null になっても確実に止められるよう保持）

// iOS/Android: 最初のタップで全曲をプライミング（事前に play→pause して再生権を確保）
function unlockAudio() {
  if (_audioUnlocked) return;
  _audioUnlocked = true;
  // AudioContext unlock (Android Chrome 等)
  try {
    const Ctx = window.AudioContext || window.webkitAudioContext;
    if (Ctx) {
      const ctx = new Ctx();
      const buf = ctx.createBuffer(1, 1, 22050);
      const src = ctx.createBufferSource();
      src.buffer = buf; src.connect(ctx.destination); src.start(0);
      ctx.resume && ctx.resume();
    }
  } catch(e) {}
  // iOS Safari: 1曲ずつ順番にプライミング（全曲同時 play はiOS音声セッション干渉で2重再生になるため禁止）
  let _primeIdx = 0;
  function primeNext() {
    if (_primeIdx >= SONGS.length) return;
    const song = SONGS[_primeIdx++];
    try {
      const a = new Audio(song);
      a.muted = true;   // ハードウェア音声出力を完全遮断（unmute はプール取得時）
      a.volume = 0.55;
      const p = a.play();
      const done = () => { a.pause(); a.currentTime = 0; _primedPool[song] = a; primeNext(); };
      if (p && typeof p.then === 'function') { p.then(done).catch(primeNext); }
      else { done(); }
    } catch(e) { primeNext(); }
  }
  primeNext();
}

// プールから取り出す（なければ新規作成）
function _getAudio(src) {
  if (_primedPool[src]) {
    const a = _primedPool[src];
    delete _primedPool[src];
    try { a.muted = false; a.currentTime = 0; a.volume = 0.55; } catch(e) {} // プール取得時に muted 解除
    return a;
  }
  return new Audio(src);
}

function _pickSong() {
  if (_usedSongs.length >= SONGS.length) _usedSongs = [];
  const avail = SONGS.map((_,i)=>i).filter(i=>!_usedSongs.includes(i));
  const idx = avail[Math.floor(Math.random()*avail.length)];
  _usedSongs.push(idx);
  return SONGS[idx];
}

function stopMusic() {
  // _openingAudio が bgmAudio と別要素になっている場合（.catch() で bgmAudio が null になった後）も止める
  if (_openingAudio && _openingAudio !== bgmAudio) {
    const oa = _openingAudio;
    _openingAudio = null;
    try { oa.onended = null; } catch(e) {}
    try { oa.pause(); } catch(e) {}
  } else {
    _openingAudio = null;
  }
  if (!bgmAudio) return;
  const a = bgmAudio;
  bgmAudio = null;
  try { a.onended = null; } catch(e) {}
  try { a.pause(); } catch(e) {}
  // src='' はiOSで誤動作（再生継続やエラーイベント発火）するため使用しない
}

// 通常再生（プールから取得）
function playMusic(src, onEnd=null) {
  stopMusic();
  const a = _getAudio(src);
  bgmAudio = a;
  a.volume = _bgmMuted ? 0 : 0.55; // ミュート中は音量0で再生（onended は正常発火させる）
  if (onEnd) a.onended = () => { if (bgmAudio===a) { bgmAudio=null; onEnd(); } };
  a.play().catch(() => { if (bgmAudio===a) bgmAudio=null; });
  return a;
}

// 同期再生: startedAt(ms) の時刻から再生位置を合わせる（同室複数スマホ対応）
function playMusicSync(src, startedAt, onEnd=null) {
  stopMusic();
  const a = _getAudio(src);
  bgmAudio = a;
  a.volume = _bgmMuted ? 0 : 0.55; // ミュート中は音量0で再生（onended は正常発火させる）
  if (onEnd) a.onended = () => { if (bgmAudio===a) { bgmAudio=null; onEnd(); } };
  // _didPlay フラグで canplay + タイムアウト二重発火（iOSでの2重再生）を防ぐ
  let _didPlay = false;
  const doPlay = () => {
    if (_didPlay) return;
    _didPlay = true;
    const offset = Math.max(0, (Date.now() - startedAt) / 1000);
    if (isFinite(a.duration) && a.duration > 1 && offset < a.duration - 2) {
      try { a.currentTime = offset; } catch(e) {}
    }
    a.play().catch(() => { if (bgmAudio===a) bgmAudio=null; });
  };
  // readyState >= 2 (HAVE_CURRENT_DATA) なら即再生、そうでなければ canplay 待ち
  if (a.readyState >= 2) {
    doPlay();
  } else {
    a.addEventListener('canplay', doPlay, { once: true });
    setTimeout(() => { if (bgmAudio===a && a.paused) doPlay(); }, 2000);
    a.load();
  }
  return a;
}

function fadeOutMusic(duration=1500, onDone=null) {
  // bgmAudio が null でも _openingAudio にフォールバック（.catch() で参照が切れた場合に対応）
  const a = bgmAudio || _openingAudio;
  if (!a) { if (onDone) onDone(); return; }
  if (bgmAudio === a) bgmAudio = null;
  _openingAudio = null;
  try { a.onended = null; } catch(e) {} // フェード中に onended が発火しないようにする
  const startVol = (a.volume > 0) ? a.volume : 0.55;
  const steps = 30;
  const ms = Math.max(30, duration/steps);
  let step = 0;
  const id = setInterval(() => {
    step++;
    try { a.volume = Math.max(0, startVol*(1-step/steps)); } catch(e){}
    if (step >= steps) {
      clearInterval(id);
      try{a.pause();}catch(e){}
      if (onDone) onDone();
    }
  }, ms);
}


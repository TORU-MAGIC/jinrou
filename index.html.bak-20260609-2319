// 推理スコア集計（solo/p2p/online のゲーム終了時に、自分の戦績として1回だけ走る）
// 各クライアントが自分のプレイヤーのスコアを計算→自分の端末のlocalStorageに保存。
function scoreGame(){
  if (!['solo','p2p','online'].includes(mode) || O._scored || !O.winner) return;
  O._scored = true;
  const players=(O.finalPlayers&&O.finalPlayers.length)?O.finalPlayers:(O.players||[]).map(p=>({name:p.name,role:undefined,alive:false}));
  // 対人戦(p2p/online)は難易度概念なし＝常に×1.0。ソロのみ難易度補正。
  const diff = (mode==='solo') ? (O.soloDiff||'normal') : 'normal';
  try {
    O.gameRecap = PROGRESS.recordGame({
      winner:O.winner, myRole:O.myRole, myName:O.playerName,
      players, notebook:O.notebook||{},
      humanVotes:O.myVotes||[], seerHits:O.mySeerHits||0, guard:O.myGuardSuccess||0,
      diff,
    });
  } catch(e) { O.gameRecap=null; O._scored=false; }
}


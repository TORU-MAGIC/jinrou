// 議論チャットの表示速度。大きいほどゆっくり。プレイヤーが画面から変更可能。
let chatSpeedMult = 1.6; // 既定はゆっくりめ（初心者が読みやすい速度）
function cycleChatSpeed() {
  // ゆっくり(1.6) → 標準(1.15) → はやい(0.85) → ゆっくり …
  chatSpeedMult = chatSpeedMult >= 1.5 ? 1.15 : (chatSpeedMult >= 1.0 ? 0.85 : 1.6);
  try { localStorage.setItem('jinrou_chatSpeed', String(chatSpeedMult)); } catch(e){}
}
function chatSpeedLabel() {
  return chatSpeedMult >= 1.5 ? '🐢 ゆっくり' : chatSpeedMult >= 1.0 ? '🚶 標準' : '🐇 はやい';
}
// 起動時に保存済み速度を復元
try { const _s = parseFloat(localStorage.getItem('jinrou_chatSpeed')); if (_s>0) chatSpeedMult = _s; } catch(e){}
// CPUが「考え中」になる時間。速度設定の影響は控えめ（主な調整は readPause 側で行う）
function typingDelay(personality) {
  const base = personality==='aggressive' ? (800+Math.random()*700) : (1000+Math.random()*1100);
  return Math.round(base * (0.8 + 0.25*chatSpeedMult)); // mult 0.85→×1.01, 1.15→×1.09, 1.6→×1.2
}
// 発言を読む間（テキスト長に比例。速度設定をそのまま反映する主レバー）
function readPause(text) {
  const len = text ? text.length : 12;
  return Math.round(Math.min(3600, 700 + len*70) * chatSpeedMult);
}


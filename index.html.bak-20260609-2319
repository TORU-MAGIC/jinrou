// ========== 役職図鑑（いつでも閲覧できる初心者向けガイド） ==========
function renderCodex() {
  const order = ['WEREWOLF','MADMAN','VILLAGER','SEER','DOCTOR','MEDIUM','NEKOMATA'];
  const cards = order.map(key => {
    const info = ROLES[key];
    if (!info) return '';
    const teamLabel = info.team === 'wolf' ? '人狼チーム' : '村人チーム';
    const teamColor = info.team === 'wolf' ? '#f87171' : '#4ade80';
    return `
      <div class="role-reveal-card" style="border-color:${info.color}; background:${info.color}10; padding:1.3rem 1.1rem; margin:.7rem 0;">
        <div style="display:flex;align-items:center;gap:.7rem;">
          <div style="font-size:2.6rem;">${info.icon}</div>
          <div style="text-align:left;">
            <div style="font-size:1.5rem;font-weight:900;color:${info.color};">${info.name}</div>
            <div style="font-size:.76rem;color:${teamColor};font-weight:700;">【${teamLabel}】</div>
          </div>
        </div>
        <div class="rrc-desc" style="text-align:left;margin-top:.6rem;">${info.desc}</div>
        <div style="text-align:left;">${roleGuideHtml(info)}</div>
      </div>`;
  }).join('');
  return `
    ${ph('📖','役職図鑑','全7役職の能力と立ち回りガイド','#818cf8')}
    <div class="card" style="border:1px solid #4338ca44;">
      <p style="color:#cbd5e1;font-size:.86rem;line-height:1.7;margin:0;">
        🎯 <strong>ゲームの目的</strong><br>
        村人チームは<strong style="color:#4ade80;">人狼を全員見つけて処刑</strong>すれば勝ち。
        人狼チームは<strong style="color:#f87171;">人狼の数が村人と同数になる</strong>まで村人を減らせば勝ちです。<br>
        昼は全員で議論して怪しい人を1人処刑し、夜は人狼が村人を襲います。これを繰り返します。
      </p>
    </div>
    <div class="card" style="border:1px solid #4338ca44;">
      <p style="color:#cbd5e1;font-size:.86rem;line-height:1.7;margin:0;">
        💬 <strong>CO（カミングアウト）とは</strong><br>
        「自分は占い師です」のように<strong>自分の役職を公開</strong>すること。
        占い師や霊媒師は情報を伝えるためにCOし、人狼や狂人は役職を<strong style="color:#f87171;">騙って（偽CO）</strong>村を惑わせます。
      </p>
    </div>
    <p class="sec-label" style="margin-top:1rem;">🎭 役職一覧</p>

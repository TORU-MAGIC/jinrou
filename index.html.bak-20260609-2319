// ========== SOLO ENGINE (サーバー不要 / GitHub Pages 対応) ==========
const SoloEngine = (() => {
  const CPU_NAMES = ['ハル','ユキ','アオイ','カイ','リン','ソラ','ナギ','ツバキ','コウ','アン','ミオ','レン','サキ','ジン','ノア'];
  let R = {};

  let _timers = [];
  function emit(msg)        { const id = setTimeout(() => handleServer(msg), 0); _timers.push(id); return id; }
  function later(ms, fn)    { const id = setTimeout(fn, ms); _timers.push(id); return id; }
  // 前ゲームの残留タイマーを全消去（リスタート時の誤発火＝フェーズ破壊を防ぐ）
  function resetTimers() {
    _timers.forEach(clearTimeout); _timers = [];
    if (R && R._humanTurnTimer) { clearTimeout(R._humanTurnTimer); R._humanTurnTimer = null; }
    if (R && R._discFallback)   { clearTimeout(R._discFallback);   R._discFallback = null; }
  }
  function shuffle(a)       { a=[...a]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }
  function rand(a)          { return a[Math.floor(Math.random()*a.length)]; }
  function rInt(lo,hi)      { return lo+Math.floor(Math.random()*(hi-lo+1)); }
  function alive()          { return R.players.filter(p=>p.alive); }
  function byName(n)        { return R.players.find(p=>p.name===n); }

  // ── 初期化 ────────────────────────────────────────────
  function init(humanName, total) {
    resetTimers(); // 前ゲームのタイマーを掃除してからR を作り直す
    total = Math.max(4, Math.min(15, total));
    const cpuPool = shuffle(CPU_NAMES.filter(n=>n!==humanName));
    const players = [{ name: humanName, isCpu: false, alive: true, role: '' }];
    for (let i=1; i<total; i++)
      players.push({ name: cpuPool[i-1]||`CPU${i}`, isCpu: true, alive: true, role: '' });

    const roles = shuffle([...CONFIGS[total]]);
    players.forEach((p,i) => p.role = roles[i]);
    // CPUにパーソナリティをランダム付与
    players.forEach(p => { if (p.isCpu) p.personality = rand(CPU_PERSONALITIES); });

    R = {
      players, day: 0, phase: 'role',
      wolfTarget: null, doctorTarget: null,
      lastDoctorTarget: null, lastExecuted: null, lastExecutedRole: null,
      humanNightDone: false, cpuNightDone: false,
      humanWolfChoice: null,
      discMsgs: [], discOrder: [], discIdx: 0, discRound: 1,
      votes: {}, humanVoted: false, tallyDone: false, resolveDone: false,
      accuCount: {}, seerKnown: {}, log: [],
    };
    BRAIN.initR(R); // BRAIN メモリ初期化

    const human = players[0];
    const wolves = players.filter(p=>p.role==='WEREWOLF');
    const wolfPartners = human.role==='WEREWOLF'
      ? wolves.filter(p=>p!==human).map(p=>p.name) : [];

    emit({
      type: 'game_started',
      role: human.role,
      wolf_partners: wolfPartners,
      players: players.map(p=>({ pid: players.indexOf(p), name: p.name })),
      is_host: true,
    });
  }

  // ── 人狼チャット ──────────────────────────────────────
  function startWolfChat() {
    R.phase = 'wolf_chat';
    BRAIN.initR(R);
    const wolves = alive().filter(p=>p.role==='WEREWOLF');
    emit({ type: 'wolf_chat_start', wolf_names: wolves.map(p=>p.name) });

    const cpuWolves = wolves.filter(p=>p.isCpu);
    const vill = alive().filter(p=>p.role!=='WEREWOLF');
    if (cpuWolves.length && vill.length) {
      const tgt = BRAIN.wolfNightTarget(R) || topAcc(vill) || rand(vill);
      let t = 1000;
      cpuWolves.forEach((w, idx) => {
        later(t, () => emit({ type:'wolf_chat_msg', name:w.name,
          text: tplFill(rand(TPL.wolf_night), tgt.name) }));
        t += 1300 + Math.floor(Math.random()*600);
      });
    }
  }

  // ── 夜フェーズ ────────────────────────────────────────
  function startNight() {
    R.day++; R.phase = 'night';
    R.wolfTarget = null; R.doctorTarget = null;
    R.humanNightDone = false; R.cpuNightDone = false;
    R.humanWolfChoice = null; R.resolveDone = false;

    const al = alive();
    emit({ type: 'night_start', day: R.day });

    // 霊媒師（処刑があった場合）
    const human = R.players[0];
    if (human.alive && human.role==='MEDIUM' && R.lastExecuted) {
      emit({ type:'medium_reveal', target:R.lastExecuted, role:R.lastExecutedRole });
    }

    if (human.alive) {
      const others = al.filter(p=>p!==human);
      // 初日から全役職が行動可能
      if (human.role==='WEREWOLF') {
        const wolfNames = al.filter(p=>p.role==='WEREWOLF').map(p=>p.name);
        emit({ type:'action_needed', action:'wolf', targets:others.filter(p=>p.role!=='WEREWOLF').map(p=>({name:p.name})), wolf_names:wolfNames });
      } else if (human.role==='SEER') {
        emit({ type:'action_needed', action:'seer', targets:others.map(p=>({name:p.name})) });
      } else if (human.role==='DOCTOR') {
        // 前夜に守った人は選択肢から除外（連続護衛禁止）
        const docTargets = al.filter(p=>p.name!==R.lastDoctorTarget);
        emit({ type:'action_needed', action:'doctor', targets:docTargets.map(p=>({name:p.name})), last_protected:R.lastDoctorTarget });
      } else {
        R.humanNightDone = true;
      }
    } else {
      R.humanNightDone = true;
    }

    later(1400, () => {
      doCpuNight();
      R.cpuNightDone = true;
      if (R.humanNightDone) later(700, resolveNight);
    });
  }

  function doCpuNight() {
    BRAIN.initR(R);
    const al = alive();
    // 占い師CPU（毎夜）: 既に黒を出してない、かばわれてない（怪しい）人を優先
    const cpuSeer = al.find(p=>p.isCpu && p.role==='SEER');
    if (cpuSeer) {
      const unknowns = al.filter(p=>p!==cpuSeer && R.seerKnown[p.name]===undefined);
      // 疑われ度の高い未占い者を優先
      let tgt = null;
      if (unknowns.length) {
        let best=-1, b=null;
        unknowns.forEach(p=>{ const s=(R.suspicion?.[p.name]||0); if(s>best){best=s;b=p;} });
        tgt = b || rand(unknowns);
      } else {
        tgt = rand(al.filter(p=>p!==cpuSeer));
      }
      if (tgt) R.seerKnown[tgt.name] = (tgt.role==='WEREWOLF');
    }
    // 人狼CPU標的（BRAIN による戦略的選択）
    const cpuWolves = al.filter(p=>p.isCpu && p.role==='WEREWOLF');
    const vill = al.filter(p=>p.role!=='WEREWOLF');
    if (cpuWolves.length && vill.length) {
      const target = BRAIN.wolfNightTarget(R) || topAcc(vill) || rand(vill);
      if (target) R.wolfTarget = target.name;
    }
    // 騎士CPU: CO占い師がいれば優先的に守る。なければ最も疑われていない=信頼度高い人
    const cpuDoc = al.find(p=>p.isCpu && p.role==='DOCTOR');
    if (cpuDoc) {
      const baseCandidates = (vill.length ? vill : al).filter(p=>p.name!==R.lastDoctorTarget && p.name!==cpuDoc.name);
      let tgt = null;
      // 1) 真の占い師COを守る
      const trueSeerCO = (R.seerCOs||[]).find(c=>{ const p=R.players.find(x=>x.name===c.name); return p && p.alive && p.role==='SEER'; });
      if (trueSeerCO) tgt = baseCandidates.find(p=>p.name===trueSeerCO.name);
      // 2) 真の霊媒師
      if (!tgt) {
        const trueMedCO = (R.mediumCOs||[]).find(c=>{ const p=R.players.find(x=>x.name===c.name); return p && p.alive && p.role==='MEDIUM'; });
        if (trueMedCO) tgt = baseCandidates.find(p=>p.name===trueMedCO.name);
      }
      // 3) なければかばわれ度が高い（信頼されてそう＝狙われやすい）人
      if (!tgt && baseCandidates.length) {
        let best=-Infinity, b=null;
        baseCandidates.forEach(p=>{ const sc=(R.coverCount?.[p.name]||0)-(R.suspicion?.[p.name]||0)*0.5; if(sc>best){best=sc;b=p;} });
        tgt = b || rand(baseCandidates);
      }
      if (tgt) R.doctorTarget = tgt.name;
    }
  }

  function resolveNight() {
    if (R.resolveDone) return;
    R.resolveDone = true;
    const wt = R.humanWolfChoice || R.wolfTarget;
    const dt = R.doctorTarget;
    // 騎士護衛対象を次夜用に記録（連続護衛禁止）
    R.lastDoctorTarget = dt;
    R.wolfTarget = null; R.doctorTarget = null; R.humanWolfChoice = null;

    let victim = null;
    if (wt && alive().some(p=>p.role==='WEREWOLF')) {
      if (dt === wt) {
        R.log.push(`第${R.day}夜: 騎士が守り、誰も死ななかった`);
      } else {
        const p = byName(wt);
        if (p && p.alive) {
          p.alive = false; victim = p;
          R.log.push(`第${R.day}夜: ${wt} が人狼に襲われた`);
          // 猫又ルール: 猫又が夜に殺されると人狼を1人道連れ
          if (p.role === 'NEKOMATA') {
            const wolves = alive().filter(x=>x.role==='WEREWOLF');
            if (wolves.length) {
              const dragged = rand(wolves);
              dragged.alive = false;
              R.log.push(`第${R.day}夜: 猫又の道連れで ${dragged.name}（人狼）も倒れた`);
            }
          }
        }
      }
    }
    const win = checkWin();
    if (win) { doGameOver(win, victim); return; }
    later(400, () => startDiscuss(victim));
  }

  // ── 議論フェーズ ──────────────────────────────────────
  function _checkVoteReady() {
    if (R.phase !== 'discuss') return;
    if (alive().every(p => R.voteReadySet.has(p.name))) {
      if (R._discFallback) { clearTimeout(R._discFallback); R._discFallback = null; }
      emit({ type: 'vote_ready_all' });
      later(1900, () => { if (R.phase === 'discuss') { R.phase = 'voting'; startVote(); } });
    }
  }

  function startDiscuss(victim) {
    R.phase = 'discuss'; R.discMsgs = [];
    R.discRound = 1; R.discIdx = 0;
    R.voteReadySet = new Set();
    R.discOrder = shuffle(alive().map(p=>p.name));
    // 楽曲を先に選んでタイムスタンプを確定（同室デバイス間での同期用）
    const song = _pickSong();
    const songStarted = Date.now() + 650; // 650ms後に再生開始
    // 音楽が流れない場合のフォールバックタイマー（5分）
    if (R._discFallback) clearTimeout(R._discFallback);
    R._discFallback = setTimeout(() => {
      if (R.phase === 'discuss') { R.phase = 'voting'; startVote(); }
    }, 5 * 60 * 1000);
    emit({
      type: 'discuss_start', round: 1, total_rounds: 2,
      eliminated: victim ? { name:victim.name } : null,
      alive: alive().map(p=>({ name:p.name })),
      song, songStarted,
    });
    later(700, advanceDisc);
  }

  function advanceDisc() {
    if (R.phase !== 'discuss') return; // 音楽終了等でフェーズ変化済みならスキップ
    if (R.discIdx >= R.discOrder.length) {
      if (R.discRound < 2) {
        R.discRound++; R.discIdx = 0;
        emit({ type:'disc_new_round', round:R.discRound });
        later(500, advanceDisc);
      } else {
        // 2ラウンド完了: 全CPUを自動レディ（人間が押すまで音楽継続）
        alive().filter(p=>p.isCpu).forEach((p,i) => {
          later(600 + i*350, () => {
            if (R.phase !== 'discuss') return;
            R.voteReadySet.add(p.name);
            emit({ type:'vote_ready_upd', readyNames:[...R.voteReadySet] });
            _checkVoteReady();
          });
        });
      }
      return;
    }
    const spName = R.discOrder[R.discIdx];
    const sp = byName(spName);
    if (!sp || !sp.alive) { R.discIdx++; advanceDisc(); return; }
    emit({ type:'disc_turn', name:spName });
    if (!sp.isCpu) {
      later(80, () => emit({ type:'your_disc_turn' }));
      // 30秒発言なしで自動進行（音楽未再生環境対策）
      if (R._humanTurnTimer) clearTimeout(R._humanTurnTimer);
      const _autoSpName = spName;
      R._humanTurnTimer = setTimeout(() => {
        if (R.phase !== 'discuss') return;
        if (R.discOrder[R.discIdx] !== _autoSpName) return; // 既に進んでいる
        R.discIdx++;
        later(200, advanceDisc);
      }, 30 * 1000);
    } else {
      // CPUの発言: 速度設定に応じて「考え中」表示 → 発言 → 読む間
      later(typingDelay(sp.personality), () => {
        if (R.phase !== 'discuss') return;
        const text = BRAIN.speak(R, sp);
        BRAIN.parseClaim(R, spName, text); // 自分の発言から claims を登録
        R.discMsgs.push({ name:spName, text });
        emit({ type:'disc_message', name:spName, text });
        R.discIdx++;
        later(readPause(text), advanceDisc); // テキスト長に比例した読む時間を確保
      });
    }
  }

  // ── 投票フェーズ ──────────────────────────────────────
  function startVote() {
    R.phase = 'vote'; R.votes = {}; R.humanVoted = false; R.tallyDone = false;
    if (R._discFallback) { clearTimeout(R._discFallback); R._discFallback = null; } // 議論フォールバックを確実に停止
    const al = alive();
    if (!R.players[0].alive) R.humanVoted = true; // 死亡プレイヤーは投票不要
    emit({ type:'vote_start', alive:al.map(p=>({ name:p.name })) });
    const cpus = al.filter(p=>p.isCpu);
    cpus.forEach((cpu, i) => {
      later(1500 + i*1200, () => {
        const tgt = BRAIN.vote(R, cpu);
        if (tgt) R.votes[cpu.name] = tgt.name;
        const done = Object.keys(R.votes).length + (R.humanVoted?1:0);
        emit({ type:'vote_progress', done, total:al.length });
        if (R.humanVoted && Object.keys(R.votes).length >= cpus.length)
          later(400, tallyVotes);
      });
    });
    if (!cpus.length) { /* only human, wait for vote */ }
  }

  function tallyVotes() {
    if (R.tallyDone) return;
    R.tallyDone = true;
    const al = alive();
    const count = {};
    al.forEach(p=>count[p.name]=0);
    Object.values(R.votes).forEach(n=>{ if(count[n]!==undefined) count[n]++; });
    let maxV=0, executed=null;
    Object.entries(count).forEach(([n,c])=>{ if(c>maxV){maxV=c;executed=n;} });
    if (!executed && al.length) executed = rand(al).name;
    const execP = byName(executed);
    if (execP) execP.alive = false;
    R.log.push(`第${R.day}日: ${executed} が処刑された`);
    // 霊媒師用に処刑情報を保存
    R.lastExecuted = executed;
    R.lastExecutedRole = execP?.role;
    // 猫又ルール: 処刑時にランダムな生存者を道連れ
    let nekomataVictim = null;
    if (execP?.role === 'NEKOMATA') {
      const bystanders = alive(); // execP は既に alive=false
      if (bystanders.length) {
        nekomataVictim = rand(bystanders);
        nekomataVictim.alive = false;
        R.log.push(`第${R.day}日: 猫又の道連れで ${nekomataVictim.name} も倒れた`);
      }
    }
    const win = checkWin();
    emit({
      type: 'vote_result',
      executed, executed_role: execP?.role, tally: count,
      nekomata_victim: nekomataVictim?.name,
      winner: win,
      players: win ? R.players.map(p=>({name:p.name,role:p.role,alive:p.alive})) : null,
      log: win ? R.log : null,
    });
    // 霊媒師（人間）に結果を通知
    const humanMedium = R.players.find(p=>!p.isCpu && p.alive && p.role==='MEDIUM');
    if (humanMedium) {
      emit({ type:'medium_reveal', target:executed, role:execP?.role });
    }
  }

  // ── ユーティリティ ────────────────────────────────────
  function checkWin() {
    const al = alive();
    const w = al.filter(p=>p.role==='WEREWOLF');
    const v = al.filter(p=>p.role!=='WEREWOLF');
    if (!w.length) return 'village';
    if (w.length >= v.length) return 'wolf';
    return null;
  }
  function doGameOver(winner, victim) {
    emit({
      type: 'game_over', winner,
      players: R.players.map(p=>({name:p.name,role:p.role,alive:p.alive})),
      log: R.log,
      eliminated: victim ? {name:victim.name,role:victim.role} : null,
    });
  }
  function topAcc(players) {
    let max=0, best=null;
    players.forEach(p=>{ const c=R.accuCount[p.name]||0; if(c>max){max=c;best=p;} });
    return best;
  }
  function cpuTpl(cpu) {
    const al = alive();
    const others = al.filter(p=>p.name!==cpu.name);
    const wasAcc = (R.accuCount[cpu.name]||0) > 0;
    const pers = cpu.personality || 'balanced';

    // ── 人狼・狂人 ──
    if (cpu.role==='WEREWOLF' || cpu.role==='MADMAN') {
      if (wasAcc) return rand(TPL.defend);
      const vill = others.filter(p=>p.role!=='WEREWOLF');
      if (pers === 'wolf_smart') {
        // 洗練された欺瞞: 時々先手防衛、高確率で告発
        if (Math.random() < 0.12) return rand(TPL.defend);
        if (vill.length && Math.random() < 0.78) {
          const tgt = topAcc(vill)||rand(vill);
          R.accuCount[tgt.name] = (R.accuCount[tgt.name]||0)+1;
          return tplFill(rand(TPL.accuse), tgt.name);
        }
        return rand(TPL.neutral);
      }
      const acProb = pers==='aggressive' ? 0.82 : 0.65;
      if (vill.length && Math.random() < acProb) {
        const tgt = topAcc(vill)||rand(vill);
        R.accuCount[tgt.name] = (R.accuCount[tgt.name]||0)+1;
        return tplFill(rand(TPL.accuse), tgt.name);
      }
      return rand(TPL.neutral);
    }

    // ── 占い師 ──
    if (cpu.role==='SEER') {
      const known = Object.entries(R.seerKnown);
      const revProb = pers==='quick_co' ? 0.88 : pers==='secretive' ? 0.20 : 0.55;
      if (known.length && Math.random() < revProb) {
        const [name, isWolf] = rand(known);
        if (isWolf) R.accuCount[name] = (R.accuCount[name]||0)+2;
        return tplFill(rand(isWolf?TPL.seer_wolf:TPL.seer_safe), name);
      }
      // quick_co: 情報がなくても占い師COする
      if (pers==='quick_co' && R.discRound===1 && Math.random()<0.65)
        return rand(['占い師としてCOします 🔮', '私が占い師です。情報を集めています 🔮', '占い師として名乗り出ます。信じてください 🔮']);
    }

    // ── 騎士 ──
    if (cpu.role==='DOCTOR') {
      const coProb = pers==='quick_co' ? 0.50 : pers==='secretive' ? 0.04 : 0.12;
      if (Math.random() < coProb)
        return rand(['騎士としてCOします 💊', '私は騎士です。誰かを守っています 💊', '騎士COします。大切な人を護衛中です 💊']);
    }

    if (wasAcc) return rand(TPL.defend);

    const accuseProb = pers==='aggressive' ? 0.70 : pers==='secretive' ? 0.10 : pers==='quick_co' ? 0.35 : 0.40;
    if (others.length && Math.random() < accuseProb) {
      const tgt = topAcc(others)||rand(others);
      R.accuCount[tgt.name] = (R.accuCount[tgt.name]||0)+1;
      return tplFill(rand(TPL.accuse), tgt.name);
    }
    if (pers==='secretive') return rand(TPL.neutral);
    if (pers==='aggressive') return rand(TPL.pressure);
    return rand([...TPL.neutral,...TPL.question].slice(0,14));
  }

  // ── クライアントからのメッセージ処理 ─────────────────
  function handle(data) {
    switch (data.type) {
      case 'start_night':
        if (R.players[0].role==='WEREWOLF') startWolfChat(); else startNight();
        break;
      case 'wolf_chat_done':
        later(400, startNight);
        break;
      case 'wolf_chat_msg':
        // ローカル表示済み、ソロではブロードキャスト不要
        break;
      case 'night_action': {
        const human = R.players[0];
        if (human.role==='WEREWOLF') {
          R.humanWolfChoice = data.target;
          emit({ type:'wolf_chosen', target:data.target });
          emit({ type:'action_ack' });
        } else if (human.role==='SEER') {
          const tgt = byName(data.target);
          const isWolf = tgt ? tgt.role==='WEREWOLF' : false;
          R.seerKnown[data.target] = isWolf;
          emit({ type:'seer_result', target:data.target, is_wolf:isWolf });
        } else if (human.role==='DOCTOR') {
          R.doctorTarget = data.target;
          emit({ type:'action_ack' });
        }
        R.humanNightDone = true;
        if (R.cpuNightDone) later(700, resolveNight);
        break;
      }
      case 'music_ended':
        if (R.phase === 'discuss') { R.phase = 'voting'; later(300, startVote); }
        break;
      case 'vote_ready':
        if (R.phase !== 'discuss') break;
        if (!R.voteReadySet) R.voteReadySet = new Set();
        R.voteReadySet.add(R.players[0].name);
        emit({ type:'vote_ready_upd', readyNames:[...R.voteReadySet] });
        _checkVoteReady();
        break;
      case 'disc_message': {
        if (R.phase !== 'discuss') break;
        const human = R.players[0];
        // BRAIN によるクレーム＆疑い解析（人間発言から CO・かばう・疑うを学習）
        BRAIN.parseClaim(R, human.name, data.text);
        R.discMsgs.push({ name:human.name, text:data.text });
        emit({ type:'disc_message', name:human.name, text:data.text });
        // 自分の順番のときだけ進める（フリー入力はターン外でも発言可）
        if (R.discOrder[R.discIdx] === human.name) {
          if (R._humanTurnTimer) { clearTimeout(R._humanTurnTimer); R._humanTurnTimer = null; }
          R.discIdx++;
          later(450, advanceDisc);
        }
        break;
      }
      case 'vote': {
        const al = alive();
        R.votes[R.players[0].name] = data.target;
        R.humanVoted = true;
        const done = Object.keys(R.votes).length;
        emit({ type:'vote_progress', done, total:al.length });
        const cpusDone = al.filter(p=>p.isCpu).every(p=>R.votes[p.name]!==undefined);
        if (cpusDone) later(500, tallyVotes);
        break;
      }
      case 'next_night':
        later(300, () => R.players[0].role==='WEREWOLF' ? startWolfChat() : startNight());
        break;
    }
  }

  return { init, handle, resetTimers };
})();


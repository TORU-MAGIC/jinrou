      <div class="card">
        <h3 style="color:#34d399; margin-bottom:.4rem;">💊 誰を護衛しますか？</h3>
        ${lastNote}
        <label>守る相手</label>${tsel}
        <button class="btn btn-primary" id="oNightSend" data-action="doctor" style="margin-top:.6rem;">🛡️　護衛する</button>
      </div>`;
  }
  if (action === 'wolf') {
    // ── ステルスUI: 周囲からは普通の「夜チェック」画面に見える ──

function tplFill(text, name) { return text.replace(/\{n\}/g, name); }

// ========== CPU BRAIN（上級者思考の中央モジュール） ==========
// SoloEngine／P2PEngine 両方の R を扱う（R.players, R.day, R.discRound, R.seerKnown など共通フィールドを使う）
const BRAIN = (function(){
  function rand(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
  function alive(R){ return R.players.filter(p=>p.alive); }
  function others(R, p){ return alive(R).filter(x=>x.name!==p.name); }
  function topAcc(R, pls){ let m=0,b=null; pls.forEach(p=>{const c=R.suspicion?.[p.name]||0;if(c>m){m=c;b=p;}}); return b; }
  function topAccLow(R, pls){ // 疑われていない順
    let m=Infinity,b=null; pls.forEach(p=>{const c=R.suspicion?.[p.name]||0;if(c<m){m=c;b=p;}}); return b;
  }

  // ── R 初期化（メモリ追加） ─────────────────────────────
  function initR(R){
    if (!R.suspicion) R.suspicion = {};
    if (!R.claims) R.claims = {};            // {name: 'SEER'|'DOCTOR'|'MEDIUM'} (本人CO履歴)
    if (!R.seerCOs) R.seerCOs = [];          // [{name, day, target?, isWolf?}]
    if (!R.mediumCOs) R.mediumCOs = [];      // [{name, day, target?, role?}]
    if (!R.docCOs) R.docCOs = [];
    if (!R.coverCount) R.coverCount = {};    // {name: 何回かばわれたか}
    if (!R.lastSpoke) R.lastSpoke = {};      // {name: 直近の発言タイプ}
    if (!R.speakCount) R.speakCount = {};    // {name: 発言数}
    if (!R.discThisRound) R.discThisRound = new Set();
    if (!R.wolfFakeSeerPlan) R.wolfFakeSeerPlan = null; // 人狼チームの騙り計画 {fakerName, fakeTarget}
    if (!R.voteHistory) R.voteHistory = [];  // [{day, votes:{voter:target}}]
    // 旧 accuCount との互換: suspicion を主用に
    if (!R.accuCount) R.accuCount = R.suspicion;
  }

  function bumpSuspicion(R, name, w=1){
    if (!name) return;
    R.suspicion[name] = (R.suspicion[name]||0) + w;
    R.accuCount[name] = R.suspicion[name]; // alias 互換
  }
  function bumpCover(R, name, w=1){
    if (!name) return;
    R.coverCount[name] = (R.coverCount[name]||0) + w;
    R.suspicion[name] = Math.max(0, (R.suspicion[name]||0) - w*0.6);
    R.accuCount[name] = R.suspicion[name];
  }

  // ── 発言からCO・結果を抽出（メッセージ解析） ───────────
  function parseClaim(R, name, text){
    if (!text) return;
    const hasNegateWolf = /(人狼|黒)\s*(?:ではない|じゃない|では無|じゃ無)/.test(text)
                       || /人狼じゃ(ない|なさそう)/.test(text);

    // 占い師CO検出
    if (/占い師(として)?CO|占い師として(名乗|宣言|出ます)|私(が|は)占い師|占い師として名乗り出ます/.test(text)) {
      if (!R.claims[name]) R.claims[name] = 'SEER';
      if (!R.seerCOs.find(c=>c.name===name)) R.seerCOs.push({name, day:R.day, results:[]});
    }
    // 騎士CO
    if (/騎士(として)?CO|私(が|は)騎士|護衛(してます|中)/.test(text)) {
      if (!R.claims[name]) R.claims[name] = 'DOCTOR';
      if (!R.docCOs.find(c=>c.name===name)) R.docCOs.push({name, day:R.day});
    }
    // 霊媒師CO
    if (/霊媒師?(として)?CO|私(が|は)霊媒|霊視|霊媒結果|霊媒師として(名乗|報告)/.test(text)) {
      if (!R.claims[name]) R.claims[name] = 'MEDIUM';
      if (!R.mediumCOs.find(c=>c.name===name)) R.mediumCOs.push({name, day:R.day, results:[]});
    }

    // 占い結果は CO 済 or 「占い」キーワード含むときだけ解析（否定文除外）
    const isSeerContext = R.claims[name]==='SEER' || /占い/.test(text);
    if (isSeerContext && !hasNegateWolf) {
      // 黒判定: 「○○さんは人狼」「○○さんに黒」「○○さんを占って黒」など
      const wolfM = text.match(/([^\s、。を]+?)さん(?:は|を|に|へ).{0,8}?(人狼(?:でした|です|だった)?|黒(?:でした|判定|です)?)/);
      if (wolfM) {
        const tgt = wolfM[1];
        const co = R.seerCOs.find(c=>c.name===name);
        if (co && !co.results.find(r=>r.target===tgt && r.day===R.day)) {
          co.results.push({day:R.day, target:tgt, isWolf:true});
        }
        bumpSuspicion(R, tgt, 3);
      } else {
        // 白判定: 「○○さんは白でした」「○○さんは村人陣営」など
        const safeM = text.match(/([^\s、。を]+?)さん(?:は|を|に|へ).{0,8}?(白(?:でした|です|判定)|村人陣営|村人でした|安全(?:でした|です)?|信頼(?:できます)?)/);
        if (safeM) {
          const tgt = safeM[1];
          const co = R.seerCOs.find(c=>c.name===name);
          if (co && !co.results.find(r=>r.target===tgt && r.day===R.day)) {
            co.results.push({day:R.day, target:tgt, isWolf:false});
          }
          bumpCover(R, tgt, 1.5);
        }
      }
    }

    // 霊媒結果
    if (R.claims[name]==='MEDIUM' && !hasNegateWolf) {
      const wolfM = text.match(/([^\s、。を]+?)さん.{0,8}?(人狼(?:でした|です)|黒(?:でした|判定)?)/);
      if (wolfM) {
        const tgt = wolfM[1];
        const co = R.mediumCOs.find(c=>c.name===name);
        if (co && !co.results.find(r=>r.target===tgt)) co.results.push({day:R.day, target:tgt, role:'WEREWOLF'});
      }
    }

    // かばう系の検出
    const coverM = text.match(/([^\s、。を]+?)さん(?:は|を).{0,12}?(人狼(?:ではない|じゃない)|怪しくない|信頼でき|白だと思|処刑(?:するの)?は反対|吊りたくない|村人っぽい|村目線|無実|疑う(?:のは|べきじゃ)|疑ってない)/);
    if (coverM) bumpCover(R, coverM[1], 1);

    // 疑う発言（否定文・かばう文は除外）
    if (!hasNegateWolf && !coverM) {
      alive(R).forEach(p=>{
        if (p.name===name) return;
        if (text.includes(p.name) && /怪しい|疑|黒|人狼|投票|処刑|吊|矛盾|嘘|騙|不自然|沈黙|発言少な/.test(text)) {
          bumpSuspicion(R, p.name, 1);
        }
      });
    }
    R.speakCount[name] = (R.speakCount[name]||0)+1;
  }

  // ── 人狼チームの「騙り占い師」計画を立てる ─────────────
  function planWolfFakeSeer(R){
    if (R.wolfFakeSeerPlan) return;
    const wolves = alive(R).filter(p=>p.role==='WEREWOLF' && p.isCpu);
    if (!wolves.length) return;
    // 大規模戦（10人以上）ならパーソナリティ問わず騙りを行う確率上昇
    const total = R.players.length;
    let tryProb = total >= 10 ? 0.85 : total >= 7 ? 0.55 : 0.30;
    tryProb = Math.min(0.95, tryProb * (window._soloSharp || 1)); // 難易度で騙り頻度を調整
    if (Math.random() > tryProb) return;
    // 騙り役は bluffer か aggressive がベスト
    const faker = wolves.find(w=>w.personality==='bluffer') || wolves.find(w=>w.personality==='aggressive') || rand(wolves);
    // 偽占い対象は村人寄りの一人
    const vill = alive(R).filter(p=>p.role!=='WEREWOLF' && p.name!==faker.name);
    if (!vill.length) return;
    const fakeTarget = rand(vill);
    R.wolfFakeSeerPlan = { fakerName: faker.name, fakeTarget: fakeTarget.name };
  }

  // ── 発言生成（メイン） ─────────────────────────────────
  function speak(R, cpu){
    initR(R);
    const pers = cpu.personality || 'logical';
    const day = R.day;
    const round = R.discRound || 1;
    const acc = R.suspicion[cpu.name]||0;
    const wasAcc = acc > 0;
    const ot = others(R, cpu);
    const al = alive(R);

    // 寡黙キャラはたまに沈黙風（中立寄り）
    if (pers==='quiet' && Math.random()<0.45) return rand(TPL.neutral);

    // ── 人狼・狂人ロジック ──
    if (cpu.role==='WEREWOLF' || cpu.role==='MADMAN') {
      return speakWolfSide(R, cpu, pers, round, wasAcc, ot);
    }
    // ── 占い師ロジック ──
    if (cpu.role==='SEER') {
      return speakSeer(R, cpu, pers, day, round, wasAcc, ot);
    }
    // ── 霊媒師ロジック ──
    if (cpu.role==='MEDIUM') {
      return speakMedium(R, cpu, pers, day, round, wasAcc, ot);
    }
    // ── 騎士ロジック ──
    if (cpu.role==='DOCTOR') {
      return speakDoctor(R, cpu, pers, day, round, wasAcc, ot);
    }
    // ── 猫又ロジック ──
    if (cpu.role==='NEKOMATA') {
      return speakNekomata(R, cpu, pers, day, round, wasAcc, ot);
    }
    // ── 村人ロジック ──
    return speakVillager(R, cpu, pers, day, round, wasAcc, ot);
  }

  // === 人狼／狂人 ===
  function speakWolfSide(R, cpu, pers, round, wasAcc, ot){
    const isMad = cpu.role==='MADMAN';
    const myTeam = isMad ? [cpu.name] : alive(R).filter(p=>p.role==='WEREWOLF').map(p=>p.name);
    const vill = ot.filter(p=>!myTeam.includes(p.name));

    // 1) 自分が疑われていたら、まず防御＋他者誘導
    if (wasAcc && Math.random()<0.7) {
      if (vill.length && Math.random()<0.5) {
        // 反撃: 別の村人を疑う方向に誘導
        const tgt = topAccLow(R, vill) || rand(vill);
        bumpSuspicion(R, tgt.name, 1);
        return tplFill(rand(TPL.accuse), tgt.name);
      }
      return rand(TPL.defend);
    }

    // 2) 騙り占い師として動く？
    planWolfFakeSeer(R);
    if (R.wolfFakeSeerPlan && R.wolfFakeSeerPlan.fakerName===cpu.name) {
      // 既に占い師COしているか？
      if (!R.claims[cpu.name]) {
        R.claims[cpu.name] = 'SEER';
        R.seerCOs.push({name:cpu.name, day:R.day, results:[]});
        // 初日CO: 結果なし。2日目以降: 偽の黒判定を真の村人に当てる
        if (R.day <= 1) return rand(TPL.co_seer_blank);
        const fakeTgt = R.wolfFakeSeerPlan.fakeTarget;
        const co = R.seerCOs.find(c=>c.name===cpu.name);
        if (co) co.results.push({day:R.day, target:fakeTgt, isWolf:true});
        bumpSuspicion(R, fakeTgt, 3);
        return tplFill(rand(TPL.co_seer_wolf), fakeTgt);
      }
      // 既にCO済 → 続きの偽結果や同調
      if (R.day >= 2 && Math.random()<0.45) {
        const fakeTgt = R.wolfFakeSeerPlan.fakeTarget;
        return tplFill(rand(TPL.co_seer_wolf), fakeTgt);
      }
    }

    // 3) 仲間の人狼が疑われていたらかばう
    const teamMates = alive(R).filter(p=>!isMad && p.role==='WEREWOLF' && p.name!==cpu.name);
    const threatenedMate = teamMates.find(m=>(R.suspicion[m.name]||0) >= 2);
    if (threatenedMate && Math.random()<0.55) {
      bumpCover(R, threatenedMate.name, 1);
      return tplFill(rand(TPL.cover), threatenedMate.name);
    }

    // 4) 真の占い師COが出ていたら反論（カウンターCO疑い）
    const trueSeers = R.seerCOs.filter(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role==='SEER';
    });
    if (trueSeers.length && Math.random()<0.35) {
      const target = trueSeers[0].name;
      bumpSuspicion(R, target, 2);
      return tplFill(rand(TPL.counter_co.concat([`${target}さんの占い、信用できない 🚨`])), target);
    }

    // 5) 一般的に村人を疑う（巧妙に）
    if (vill.length) {
      const aggrProb = pers==='aggressive' ? 0.78 : pers==='bluffer' ? 0.65 : 0.55;
      if (Math.random() < aggrProb) {
        // 既に疑われている人にさらに疑いを乗せる（自然な多数派形成）
        const tgt = topAcc(R, vill) || rand(vill);
        bumpSuspicion(R, tgt.name, 1);
        // 理由付き
        const flavor = Math.random();
        if (flavor<0.25) return tplFill(rand(TPL.reason_silent), tgt.name);
        if (flavor<0.5)  return tplFill(rand(TPL.reason_pivot), tgt.name);
        if (flavor<0.7)  return tplFill(rand(TPL.vote_decl), tgt.name);
        return tplFill(rand(TPL.accuse), tgt.name);
      }
    }

    // 6) たまに白の村人をかばって誠実そうに見せる
    if (vill.length && Math.random()<0.20) {
      const tgt = topAccLow(R, vill);
      if (tgt) { bumpCover(R, tgt.name, 1); return tplFill(rand(TPL.cover), tgt.name); }
    }

    return rand([...TPL.neutral, ...TPL.question]);
  }

  // === 占い師 ===
  function speakSeer(R, cpu, pers, day, round, wasAcc, ot){
    // 偽占い師（人狼側）が既にCOしているか？
    const fakeSeerExists = R.seerCOs.some(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role!=='SEER';
    });

    // 既に自分でCO済か
    const alreadyCO = R.claims[cpu.name]==='SEER';

    // CO戦略
    const totalPlayers = R.players.length;
    const shouldCO = (
      fakeSeerExists ||                  // 騙り対抗COは即時
      (R.seerKnown && Object.values(R.seerKnown).some(v=>v===true)) || // 黒を引いたら即時
      (day >= 2) ||                       // 2日目以降は基本CO
      (pers==='aggressive' && round===1) || // 攻撃型は初日CO
      (totalPlayers >= 10 && day >= 1)     // 大規模戦は初日CO推奨
    );

    if (shouldCO && !alreadyCO) {
      R.claims[cpu.name] = 'SEER';
      if (!R.seerCOs.find(c=>c.name===cpu.name)) R.seerCOs.push({name:cpu.name, day, results:[]});
      // 結果がある場合
      const known = Object.entries(R.seerKnown||{});
      const wolfHit = known.find(([n,iw])=>iw===true);
      if (wolfHit) {
        const co = R.seerCOs.find(c=>c.name===cpu.name);
        if (co) co.results.push({day, target:wolfHit[0], isWolf:true});
        bumpSuspicion(R, wolfHit[0], 4);
        return tplFill(rand(TPL.co_seer_wolf), wolfHit[0]);
      }
      const safeHit = known.find(([n,iw])=>iw===false);
      if (safeHit) {
        const co = R.seerCOs.find(c=>c.name===cpu.name);
        if (co) co.results.push({day, target:safeHit[0], isWolf:false});
        bumpCover(R, safeHit[0], 2);
        return tplFill(rand(TPL.co_seer_safe), safeHit[0]);
      }
      return rand(TPL.co_seer_blank);
    }

    // CO済の場合は時々追加情報を出す
    if (alreadyCO) {
      const known = Object.entries(R.seerKnown||{});
      // まだ公開していない結果があれば公開
      const myCO = R.seerCOs.find(c=>c.name===cpu.name);
      const reportedTargets = new Set((myCO?.results||[]).map(r=>r.target));
      const unreported = known.filter(([n])=>!reportedTargets.has(n));
      if (unreported.length && Math.random()<0.6) {
        const [tgt, iw] = rand(unreported);
        if (myCO) myCO.results.push({day, target:tgt, isWolf:iw});
        if (iw) { bumpSuspicion(R, tgt, 3); return tplFill(rand(TPL.co_seer_wolf), tgt); }
        bumpCover(R, tgt, 1.5); return tplFill(rand(TPL.co_seer_safe), tgt);
      }
    }

    // CO してない or 報告すべき情報がない → 普通の村人ロール
    if (wasAcc) return rand(TPL.defend);
    if (ot.length && Math.random()<0.35) {
      const tgt = topAcc(R, ot) || rand(ot);
      return tplFill(rand(TPL.accuse), tgt.name);
    }
    return rand([...TPL.neutral, ...TPL.ask_co]);
  }

  // === 霊媒師 ===
  function speakMedium(R, cpu, pers, day, round, wasAcc, ot){
    const alreadyCO = R.claims[cpu.name]==='MEDIUM';
    // 偽霊媒対抗COで必要なら即CO
    const fakeMediumExists = R.mediumCOs.some(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role!=='MEDIUM';
    });
    // 処刑があってかつ霊媒結果を持っていたら CO推奨
    const hasResult = R.lastExecuted && R.lastExecutedRole;
    const shouldCO = fakeMediumExists || (hasResult && day>=2) || (pers==='aggressive' && hasResult);

    if (shouldCO && !alreadyCO) {
      R.claims[cpu.name] = 'MEDIUM';
      R.mediumCOs.push({name:cpu.name, day, results:[]});
      if (hasResult) {
        const isWolf = R.lastExecutedRole==='WEREWOLF';
        const co = R.mediumCOs.find(c=>c.name===cpu.name);
        if (co) co.results.push({day, target:R.lastExecuted, role:R.lastExecutedRole});
        if (isWolf) return tplFill(rand(TPL.medium_result_wolf), R.lastExecuted);
        return tplFill(rand(TPL.medium_result_safe), R.lastExecuted);
      }
      return rand(TPL.co_medium);
    }
    // 通常は隠れる
    if (wasAcc) return rand(TPL.defend);
    if (ot.length && Math.random()<0.35) {
      const tgt = topAcc(R, ot) || rand(ot);
      return tplFill(rand(TPL.accuse), tgt.name);
    }
    return rand([...TPL.neutral, ...TPL.ask_co]);
  }

  // === 騎士 ===
  function speakDoctor(R, cpu, pers, day, round, wasAcc, ot){
    const alreadyCO = R.claims[cpu.name]==='DOCTOR';
    // 騎士は基本隠れる。疑われたら防御COする。
    if (wasAcc && (R.suspicion[cpu.name]||0) >= 2 && !alreadyCO && Math.random()<0.55) {
      R.claims[cpu.name] = 'DOCTOR';
      R.docCOs.push({name:cpu.name, day});
      return rand(TPL.co_doctor);
    }
    if (pers==='aggressive' && day>=2 && !alreadyCO && Math.random()<0.20) {
      R.claims[cpu.name] = 'DOCTOR';
      R.docCOs.push({name:cpu.name, day});
      return rand(TPL.co_doctor);
    }
    if (wasAcc) return rand(TPL.defend);
    // 占い師をかばう（信頼している占い師が居れば）
    const trueSeer = R.seerCOs.find(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role==='SEER';
    });
    if (trueSeer && Math.random()<0.30) {
      bumpCover(R, trueSeer.name, 1);
      return tplFill(rand(TPL.cover), trueSeer.name);
    }
    if (ot.length && Math.random()<0.32) {
      const tgt = topAcc(R, ot) || rand(ot);
      return tplFill(rand(TPL.accuse), tgt.name);
    }
    return rand([...TPL.neutral, ...TPL.question]);
  }

  // === 猫又 ===
  function speakNekomata(R, cpu, pers, day, round, wasAcc, ot){
    // 普通の村人として振る舞う。終盤たまに脅し気味に。
    if (wasAcc && day>=3 && Math.random()<0.35) {
      return '私を処刑するなら覚悟しろ、道連れがいる 🐱⚡';
    }
    return speakVillager(R, cpu, pers, day, round, wasAcc, ot);
  }

  // === 村人 ===
  function speakVillager(R, cpu, pers, day, round, wasAcc, ot){
    if (wasAcc) {
      if (Math.random()<0.65) return rand(TPL.defend);
    }
    // 直近の占い情報があれば、それに基づいて投票を呼びかけ
    const trueSeers = R.seerCOs.filter(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive;
    });
    if (trueSeers.length && Math.random()<0.30) {
      // 黒判定された人がいればそれに投票宣言
      const co = trueSeers[0];
      const blackResult = (co.results||[]).find(r=>r.isWolf);
      if (blackResult) {
        bumpSuspicion(R, blackResult.target, 2);
        return tplFill(rand(TPL.vote_decl), blackResult.target);
      }
    }
    // パーソナリティ別ロジック
    if (pers==='analytical' && Math.random()<0.45) {
      // 矛盾・パターン指摘
      const tgt = topAcc(R, ot);
      if (tgt) {
        const flavor = Math.random();
        if (flavor<0.4) return tplFill(rand(TPL.reason_pivot), tgt.name);
        if (flavor<0.7) return tplFill(rand(TPL.reason_silent), tgt.name);
        return tplFill(rand(TPL.reason_defensive), tgt.name);
      }
    }
    if (pers==='follower' && Math.random()<0.55) {
      // 多数派に同調
      const tgt = topAcc(R, ot);
      if (tgt) {
        if (Math.random()<0.5) return tplFill(rand(TPL.agree), tgt.name);
        return tplFill(rand(TPL.support), tgt.name);
      }
    }
    if (pers==='cautious') {
      // 慎重派: かばう寄り
      if (Math.random()<0.40) {
        const safest = topAccLow(R, ot);
        if (safest) { bumpCover(R, safest.name, 1); return tplFill(rand(TPL.cover), safest.name); }
      }
      if (Math.random()<0.30) return rand(TPL.disagree);
      return rand([...TPL.neutral, ...TPL.question]);
    }
    if (pers==='aggressive') {
      const tgt = topAcc(R, ot) || rand(ot);
      if (tgt) { bumpSuspicion(R, tgt.name, 1); return tplFill(rand(TPL.accuse), tgt.name); }
      return rand(TPL.pressure);
    }
    if (pers==='talkative') {
      // よく喋る: いろんなテンプレを混ぜる
      const pool = [...TPL.neutral, ...TPL.question, ...TPL.ask_co];
      if (ot.length && Math.random()<0.45) {
        const tgt = topAcc(R, ot) || rand(ot);
        bumpSuspicion(R, tgt.name, 0.5);
        return tplFill(rand(TPL.accuse), tgt.name);
      }
      return rand(pool);
    }
    if (pers==='quiet') {
      return rand(TPL.neutral);
    }
    if (pers==='bluffer' && day===1 && round===1 && Math.random()<0.18) {
      // bluffer の村人はまれに占い師騙り（村人騙りは普通NGだが多様性のため）
      // → やめておく。村人騙りは混乱を招くだけなので
    }
    // logical: バランス型・推理重視
    if (ot.length && Math.random()<0.45) {
      const tgt = topAcc(R, ot) || rand(ot);
      bumpSuspicion(R, tgt.name, 1);
      const flavor = Math.random();
      if (flavor<0.3) return tplFill(rand(TPL.reason_silent), tgt.name);
      if (flavor<0.55) return tplFill(rand(TPL.reason_pivot), tgt.name);
      if (flavor<0.75) return tplFill(rand(TPL.accuse), tgt.name);
      return tplFill(rand(TPL.vote_decl), tgt.name);
    }
    if (Math.random()<0.25) return rand(TPL.disagree);
    return rand([...TPL.neutral, ...TPL.question, ...TPL.ask_co]);
  }

  // ── 投票決定（上級者ロジック） ─────────────────────────
  function vote(R, cpu){
    initR(R);
    const al = alive(R);
    const ot = al.filter(p=>p.name!==cpu.name);
    if (!ot.length) return null;

    const isWolfTeam = (cpu.role==='WEREWOLF'||cpu.role==='MADMAN');

    if (isWolfTeam) {
      // 人狼陣営: 仲間に投票しない
      const wolves = al.filter(p=>p.role==='WEREWOLF');
      const wolfNames = new Set(wolves.map(p=>p.name));
      const vill = ot.filter(p=>!wolfNames.has(p.name));
      // 真の占い師（COしてる）を優先的に処刑
      const trueSeer = R.seerCOs.find(c=>{
        const p = R.players.find(x=>x.name===c.name);
        return p && p.alive && p.role==='SEER';
      });
      if (trueSeer && vill.find(p=>p.name===trueSeer.name) && Math.random()<0.85) {
        return vill.find(p=>p.name===trueSeer.name);
      }
      // 真の霊媒師を処刑
      const trueMedium = R.mediumCOs.find(c=>{
        const p = R.players.find(x=>x.name===c.name);
        return p && p.alive && p.role==='MEDIUM';
      });
      if (trueMedium && vill.find(p=>p.name===trueMedium.name) && Math.random()<0.7) {
        return vill.find(p=>p.name===trueMedium.name);
      }
      // 騙り役の偽結果対象を吊って騙り信用を上げる
      const plan = R.wolfFakeSeerPlan;
      if (plan && vill.find(p=>p.name===plan.fakeTarget) && Math.random()<0.6) {
        return vill.find(p=>p.name===plan.fakeTarget);
      }
      // それ以外は最も疑われている村人へ
      return topAcc(R, vill) || rand(vill);
    }

    // ── 村人陣営 ──
    // 1) 占い師の黒判定がある場合は最優先
    const seerCOAlive = R.seerCOs.filter(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive;
    });
    // 占い師が1人だけなら信用する
    if (seerCOAlive.length===1) {
      const co = seerCOAlive[0];
      const blackResult = (co.results||[]).find(r=>r.isWolf);
      if (blackResult) {
        const tgt = ot.find(p=>p.name===blackResult.target);
        if (tgt) return tgt;
      }
    }
    // 占い師が複数（騙り合戦）→ より信頼度高い方を信じる
    if (seerCOAlive.length >= 2) {
      // 騎士COが守ってる方を信じる、霊媒結果と一致する方など... 簡易版: ランダムで信頼を選ぶ
      // CPU自身が占い師なら自分を信じる
      const ownCO = seerCOAlive.find(c=>c.name===cpu.name);
      if (ownCO) {
        const blk = (ownCO.results||[]).find(r=>r.isWolf);
        if (blk) {
          const t = ot.find(p=>p.name===blk.target);
          if (t) return t;
        }
      }
      // それ以外は対立してる占い師の片方を吊る（人狼騙りを潰す可能性が高い疑われてる方）
      const candidates = seerCOAlive.map(c=>ot.find(p=>p.name===c.name)).filter(Boolean);
      if (candidates.length) {
        const tgt = topAcc(R, candidates) || rand(candidates);
        if (tgt) return tgt;
      }
    }
    // 2) 霊媒師の結果（前日処刑者が白だった場合は次日に占い対立してる人を吊る → 上記で対応）
    // 3) 最も疑われている人へ投票
    const susp = topAcc(R, ot);
    if (susp && (R.suspicion[susp.name]||0) >= 1) return susp;
    return rand(ot);
  }

  // ── 人狼の夜の襲撃対象（智略つき） ─────────────────────
  function wolfNightTarget(R){
    initR(R);
    const al = alive(R);
    const wolves = al.filter(p=>p.role==='WEREWOLF');
    if (!wolves.length) return null;
    const vill = al.filter(p=>p.role!=='WEREWOLF');
    if (!vill.length) return null;

    // 1) CO占い師（真物）優先
    const trueSeer = R.seerCOs.find(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role==='SEER';
    });
    if (trueSeer) {
      const v = vill.find(p=>p.name===trueSeer.name);
      if (v) return v;
    }
    // 2) 真の霊媒師
    const trueMedium = R.mediumCOs.find(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role==='MEDIUM';
    });
    if (trueMedium) {
      const v = vill.find(p=>p.name===trueMedium.name);
      if (v) return v;
    }
    // 3) 騎士COしている真物
    const trueDoc = R.docCOs.find(c=>{
      const p = R.players.find(x=>x.name===c.name);
      return p && p.alive && p.role==='DOCTOR';
    });
    if (trueDoc) {
      const v = vill.find(p=>p.name===trueDoc.name);
      if (v && Math.random()<0.6) return v;
    }
    // 4) 一切COしてない村人で発言力ある人（疑い役の少ない＝信頼されてそうな村人）を狙う
    const noClaim = vill.filter(p=>!R.claims[p.name]);
    if (noClaim.length) {
      // かばわれてる（信頼されてる）人を優先的に狩る
      let best = null, bestScore = -Infinity;
      noClaim.forEach(p=>{
        const cover = R.coverCount[p.name]||0;
        const susp = R.suspicion[p.name]||0;
        const score = cover - susp*0.5;
        if (score > bestScore) { bestScore = score; best = p; }
      });
      if (best) return best;
    }
    return rand(vill);
  }

  return { initR, parseClaim, speak, vote, wolfNightTarget, bumpSuspicion, bumpCover };
})();

// ========== PROGRESSION & DETECTIVE SCORE（ソロの成長・中毒性レイヤー） ==========
// localStorage に戦績を保存し、推理スコア→経験値→探偵ランクへ成長させる。
// マルチプレイには一切影響しない（mode==='solo' のときだけ呼ばれる）。
const PROGRESS = (() => {
  const KEY = 'jinrou_profile_v2';

  const RANKS = [
    { min: 1,  name: '村の新入り',   icon: '🌱', color:'#94a3b8' },
    { min: 3,  name: '見習い探偵',   icon: '🔍', color:'#60a5fa' },
    { min: 5,  name: '一人前の探偵', icon: '🕵️', color:'#34d399' },
    { min: 8,  name: '名探偵',       icon: '🎩', color:'#a78bfa' },
    { min: 12, name: '人狼ハンター', icon: '🏹', color:'#fbbf24' },
    { min: 17, name: '月夜の賢者',   icon: '🌙', color:'#f472b6' },
    { min: 24, name: '伝説の村長',   icon: '👑', color:'#f59e0b' },
  ];
  function rankFor(level){ let r=RANKS[0]; for(const x of RANKS){ if(level>=x.min) r=x; } return r; }
  function reqForNext(level){ return 80 + (level-1)*45; }
  function levelInfo(totalXp){
    let level=1, rem=Math.max(0, totalXp|0);
    while(rem >= reqForNext(level) && level<200){ rem-=reqForNext(level); level++; }
    return { level, intoLevel:rem, neededForNext:reqForNext(level), rank:rankFor(level), totalXp:Math.max(0,totalXp|0) };
  }

  function blank(){
    return { totalXp:0, gamesPlayed:0, wins:0, streak:0, bestStreak:0,
             roleWins:{}, achievements:[], perfectReads:0,
             daily:{ date:null, id:null, done:false }, dailyCombo:0, dailyLastDate:null };
  }
  function load(){
    try { const j = JSON.parse(localStorage.getItem(KEY)); if(j&&typeof j==='object'){ return Object.assign(blank(), j); } } catch(e){}
    return blank();
  }
  function save(p){ try { localStorage.setItem(KEY, JSON.stringify(p)); } catch(e){} }

  function todayStr(d){ d=d||new Date(); const z=n=>String(n).padStart(2,'0'); return `${d.getFullYear()}-${z(d.getMonth()+1)}-${z(d.getDate())}`; }
  function hash(s){ let h=0; for(let i=0;i<s.length;i++){ h=(h*31+s.charCodeAt(i))|0; } return Math.abs(h); }

  // デイリーミッション（役職に依存せず達成可能なものを中心に）
  const MISSIONS = [
    { id:'win',     label:'今日の勝利を掴め',                bonus:60, check:(c)=>c.won },
    { id:'catch',   label:'投票で人狼陣営を処刑に追い込め',  bonus:60, check:(c)=>c.voteHits>=1 },
    { id:'note',    label:'捜査ノートで人狼を見抜け',        bonus:60, check:(c)=>c.correctSuspects>=1 },
    { id:'survive', label:'最後まで生き延びろ',              bonus:55, check:(c)=>c.survived },
    { id:'clean',   label:'無実の村人を誤認せず推理せよ',    bonus:70, check:(c)=>c.correctSuspects>=1 && c.wrongSuspects===0 },
    { id:'streak2', label:'2連勝を達成せよ',                 bonus:80, check:(c)=>c.won && c.streakAfter>=2 },
  ];
  function missionFor(dateStr){ dateStr=dateStr||todayStr(); return MISSIONS[hash(dateStr)%MISSIONS.length]; }

  const ACHIEVEMENTS = [
    { id:'first_game', icon:'🎮', name:'初陣',         desc:'はじめてゲームを完了した',            test:(p,c)=>p.gamesPlayed>=1 },
    { id:'first_win',  icon:'🏆', name:'初勝利',       desc:'はじめて勝利した',                    test:(p,c)=>c.won },
    { id:'streak3',    icon:'🔥', name:'三連勝',       desc:'3連勝を達成',                         test:(p,c)=>p.streak>=3 },
    { id:'streak5',    icon:'💥', name:'五連勝',       desc:'5連勝を達成',                         test:(p,c)=>p.streak>=5 },
    { id:'perfect',    icon:'🧠', name:'完全推理',     desc:'6人以上の戦で全人狼を的中＆誤認ゼロ', test:(p,c)=>c.players>=6 && c.wolvesTotal>=1 && c.correctSuspects>=c.wolvesTotal && c.wrongSuspects===0 },
    { id:'seer_win',   icon:'🔮', name:'占星術の冴え', desc:'占い師で勝利',                        test:(p,c)=>c.won && c.myRole==='SEER' },
    { id:'wolf_win',   icon:'🐺', name:'月夜の狩人',   desc:'人狼陣営で勝利',                      test:(p,c)=>c.won && c.myTeam==='wolf' },
    { id:'guardian',   icon:'🛡️', name:'鉄壁の守護',   desc:'騎士で護衛を成功させ勝利',            test:(p,c)=>c.won && c.myRole==='DOCTOR' && c.guard>=1 },
    { id:'survivor',   icon:'🍀', name:'生存者',       desc:'7人以上の戦で生き残って勝利',         test:(p,c)=>c.won && c.survived && c.players>=7 },
    { id:'detective',  icon:'🎩', name:'名探偵',       desc:'名探偵ランクに到達',                  test:(p,c)=>levelInfo(p.totalXp).level>=8 },
    { id:'daily3',     icon:'📅', name:'皆勤賞',       desc:'デイリーを3日連続で達成',             test:(p,c)=>p.dailyCombo>=3 },
    { id:'veteran',    icon:'🎖️', name:'歴戦の村人',   desc:'20ゲームをプレイ',                    test:(p,c)=>p.gamesPlayed>=20 },
  ];

  // 推理スコアの内訳を計算
  function computeScore(c){
    const lines = [];
    const add = (label, pts) => { if(Math.round(pts)!==0) lines.push({label, pts:Math.round(pts)}); };
    add(c.won ? '🏆 勝利ボーナス' : '🎌 参加ボーナス', c.won ? 120 : 25);
    if (c.survived) add('🍀 最後まで生存', 25);
    let noteNet = c.correctSuspects*30 + c.correctTrusts*12 - c.wrongSuspects*12 - c.wrongTrusts*18;
    if (noteNet!==0 || c.markCount>0) add(`🕵️ 捜査ノート（的中${c.correctSuspects}・誤認${c.wrongSuspects}）`, noteNet);
    if (c.voteHits>0) add(`🗳️ ${c.myTeam==='wolf'?'村人を欺く投票':'人狼への的中投票'} ×${c.voteHits}`, c.voteHits*18);
    if (c.myRole==='SEER'   && c.seerHits>0) add(`🔮 占いで人狼を発見 ×${c.seerHits}`, c.seerHits*14);
    if (c.myRole==='DOCTOR' && c.guard>0)    add(`💊 護衛成功 ×${c.guard}`, c.guard*18);
    const subtotal = lines.reduce((a,b)=>a+b.pts,0);
    const diffMult = c.diff==='hard'?1.3 : c.diff==='easy'?0.8 : 1.0;
    if (diffMult!==1) add(`⚙️ 難易度補正（${c.diff==='hard'?'むずかしい':'やさしい'}）`, subtotal*(diffMult-1));
    const total = Math.max(5, Math.round(subtotal*diffMult));
    return { lines, total };
  }

  function recordGame(ctx){
    const p = load();
    const isWolfTeam = r => r==='WEREWOLF' || r==='MADMAN';
    const me = (ctx.players||[]).find(x=>x.name===ctx.myName) || {};
    const survived = !!me.alive;
    const myTeam = (ROLES[ctx.myRole]||{}).team || 'village';
    const won = myTeam === ctx.winner;
    const others = (ctx.players||[]).filter(x=>x.name!==ctx.myName);
    const wolvesTotal = others.filter(x=>isWolfTeam(x.role)).length;
    const nb = ctx.notebook||{};
    let correctSuspects=0, wrongSuspects=0, correctTrusts=0, wrongTrusts=0, markCount=0;
    others.forEach(x=>{
      const m = nb[x.name]; if(!m) return; markCount++;
      const wolf = isWolfTeam(x.role);
      if(m==='suspect'){ wolf?correctSuspects++:wrongSuspects++; }
      else if(m==='trust'){ wolf?wrongTrusts++:correctTrusts++; }
    });
    const roleOf = n => { const f=(ctx.players||[]).find(x=>x.name===n); return f?f.role:null; };
    let voteHits=0;
    (ctx.humanVotes||[]).forEach(t=>{ const r=roleOf(t); if(r==null) return;
      if(myTeam==='wolf'){ if(!isWolfTeam(r)) voteHits++; } else { if(isWolfTeam(r)) voteHits++; } });
    const streakAfter = won ? (p.streak+1) : 0;
    const sc = computeScore({ won, survived, myTeam, myRole:ctx.myRole,
      correctSuspects, wrongSuspects, correctTrusts, wrongTrusts, markCount,
      voteHits, seerHits:ctx.seerHits||0, guard:ctx.guard||0, diff:ctx.diff||'normal' });

    // デイリー
    const tStr = todayStr();
    const mission = missionFor(tStr);
    let dailyJustDone=false, dailyBonus=0;
    if (p.daily.date !== tStr) p.daily = { date:tStr, id:mission.id, done:false };
    if (!p.daily.done && mission.check({ won, survived, voteHits, correctSuspects, wrongSuspects, streakAfter })) {
      p.daily.done = true; dailyJustDone=true; dailyBonus = mission.bonus;
      const y = todayStr(new Date(Date.now()-86400000));
      p.dailyCombo = (p.dailyLastDate===y) ? (p.dailyCombo+1) : 1;
      p.dailyLastDate = tStr;
    }

    // プロフィール更新
    const before = levelInfo(p.totalXp);
    const xpGained = sc.total + dailyBonus;
    p.totalXp += xpGained;
    p.gamesPlayed += 1;
    if (won) { p.wins+=1; p.streak+=1; p.bestStreak=Math.max(p.bestStreak,p.streak);
               p.roleWins[ctx.myRole]=(p.roleWins[ctx.myRole]||0)+1; }
    else p.streak = 0;
    if (correctSuspects>=wolvesTotal && wolvesTotal>=1 && wrongSuspects===0 && (ctx.players||[]).length>=6) p.perfectReads+=1;

    // 実績
    const achCtx = { won, survived, myRole:ctx.myRole, myTeam, players:(ctx.players||[]).length,
      wolvesTotal, correctSuspects, wrongSuspects, guard:ctx.guard||0 };
    const newAch = [];
    ACHIEVEMENTS.forEach(a=>{ if(!p.achievements.includes(a.id) && a.test(p, achCtx)){ p.achievements.push(a.id); newAch.push(a); } });

    const after = levelInfo(p.totalXp);
    save(p);
    return {
      scoreLines: sc.lines, scoreTotal: sc.total,
      xpGained, dailyBonus, dailyJustDone, mission, dailyDone:p.daily.done,
      before, after, leveledUp: after.level>before.level, rankChanged: after.rank.name!==before.rank.name,
      won, survived, streak:p.streak, bestStreak:p.bestStreak, newAchievements:newAch,
      gamesPlayed:p.gamesPlayed, wins:p.wins,
      winRate: p.gamesPlayed?Math.round(p.wins/p.gamesPlayed*100):0,
      achTotal:ACHIEVEMENTS.length, achHave:p.achievements.length,
    };
  }

  function summary(){
    const p = load();
    const info = levelInfo(p.totalXp);
    const tStr = todayStr();
    const mission = missionFor(tStr);
    return { profile:p, info, mission, dailyDone:(p.daily.date===tStr && p.daily.done),
      winRate: p.gamesPlayed?Math.round(p.wins/p.gamesPlayed*100):0,
      achTotal:ACHIEVEMENTS.length, achHave:p.achievements.length,
      achievements: ACHIEVEMENTS.map(a=>({...a, have:p.achievements.includes(a.id)})) };
  }
  function reset(){ save(blank()); }

  return { recordGame, summary, levelInfo, rankFor, missionFor, todayStr, RANKS, ACHIEVEMENTS, reset };
})();


    deadPlayers: [],  // [{ name, role, avatar, day }]
    // 投票開始ボタン
    voteReadyNames: [], voteReadyAll: false,
    // 人狼夜選択（ステルス）
    _wolfNightSel: null,
    // 霊媒師
    mediumReveal: null,
    // P2P固有
    p2pSub: 'choose', soloTotal: 5,
    // 成長システム（捜査ノート・難易度・リザルト）※ solo/p2p/online 共通
    notebook: {}, soloDiff: 'normal', gameRecap: null, _scored: false,
    // 戦績スコア用の自己追跡（自分の投票履歴・占い的中・護衛成功）
    myVotes: [], mySeerHits: 0, myGuardSuccess: 0, _myLastGuard: null,
  };
  if (typeof window!=='undefined') window._soloSharp = 1.0; // 難易度はsoloStartで上書き
}
initOnline();

function wsConnect(addr, onOpen) {
  const url = addr.startsWith('ws') ? addr : `ws://${addr}`;
  try {
    O.ws = new WebSocket(url);
  } catch(e) { alert('接続できませんでした: ' + e.message); return; }
  O.ws.onopen = onOpen;
  O.ws.onmessage = e => { try { handleServer(JSON.parse(e.data)); } catch(err) {} };
  O.ws.onerror = () => { alert('WebSocket エラー。サーバーが起動しているか確認してください。'); };
  O.ws.onclose = () => {
    if (O.phase !== 'game_over' && O.phase !== 'setup') {
      alert('サーバーとの接続が切れました');
      initOnline(); mode = 'home'; render();
    }
  };
}

function wsSend(msg) {
  if (mode === 'solo')  { SoloEngine.handle(msg); return; }
  if (mode === 'p2p')   { P2PEngine.wsSendP2P(msg); return; }
  if (O.ws && O.ws.readyState === WebSocket.OPEN) O.ws.send(JSON.stringify(msg));
}

function handleServer(data) {
  switch(data.type) {
    case 'room_created':
      O.roomCode = data.code; O.pid = data.pid; O.isHost = true;
      O.players = data.players; O.phase = 'lobby'; break;
    case 'room_joined':
      O.roomCode = data.code; O.pid = data.pid; O.isHost = false;
      O.players = data.players; O.phase = 'lobby'; break;
    case 'player_joined': case 'player_left':
      O.players = data.players; break;
    case 'became_host':
      O.isHost = true; break;
    case 'cpu_count_updated':
      O.cpuCount = data.count; break;
    case 'game_started':
      O.myRole = data.role; O.wolfPartners = data.wolf_partners || [];
      O.players = data.players; O.isHost = data.is_host || O.isHost;
      O.phase = 'role';
      if (['solo','p2p','online'].includes(mode)) {
        O.notebook = {}; O._scored = false; O.gameRecap = null;
        O.myVotes = []; O.mySeerHits = 0; O.myGuardSuccess = 0; O._myLastGuard = null;
      }
      break;
    case 'wolf_chat_start':
      O.wolfPartnerNames = data.wolf_names || [];
      O.wolfChatMsgs = []; O.wolfChatReady = false;
      // alive リストをプレイヤー全員で初期化（夜前なので全員生存）
      if (!O.alive || !O.alive.length) O.alive = O.players.map(p=>({ name: p.name }));
      O.phase = 'wolf_chat'; break;
    case 'wolf_chat_msg':
      O.wolfChatMsgs.push({name: data.name, text: data.text}); break;
    case 'night_start':
      O.day = data.day; O.nightActionNeeded = null;
      O.nightActionDone = false; O.seerResult = null; O.wolfChosen = null;
      O.phase = 'night'; break;
    case 'action_needed':
      O.nightActionNeeded = data; break;
    case 'seer_result':
      O.seerResult = {target: data.target, isWolf: data.is_wolf};
      if (data.is_wolf) O.mySeerHits = (O.mySeerHits||0) + 1; // 戦績: 占いで人狼発見
      O.nightActionDone = true; break;
    case 'action_ack': case 'wolf_chosen':
      if (data.type === 'wolf_chosen') O.wolfChosen = data.target;
      O.nightActionDone = true; break;
    case 'discuss_start':
      O.discMsgs = []; O.discRound = data.round; O.discTotalRounds = data.total_rounds;
      O.eliminatedLastNight = data.eliminated; O.alive = data.alive;
      // 戦績: 騎士の護衛成功を夜明けの結果から推定（守った夜に死者ゼロ＝成功）
      if (O.myRole==='DOCTOR' && O._myLastGuard) {
        if (!data.eliminated) O.myGuardSuccess = (O.myGuardSuccess||0) + 1;
        O._myLastGuard = null;
      }
      O.currentSpeaker = null; O.isMyDiscTurn = false; O.tplStep = null;
      O.voteReadyNames = []; O.voteReadyAll = false;
      // 夜に殺された人を死亡リストへ（役職確定）
      if (data.eliminated) {
        const av = getAvatar(data.eliminated.name, O.players);
        if (!O.deadPlayers.find(d=>d.name===data.eliminated.name))
          O.deadPlayers.push({ name:data.eliminated.name, role:null, avatar:av, day:O.day, cause:'人狼' });
        delete O.roleClaims[data.eliminated.name];
      }
      O.phase = 'discuss';
      O._musicFailTimer = null;
      if (data.eliminated) { setTimeout(() => showKillDrama(data.eliminated.name, data.eliminated.role), 400); }
      // 議論BGM開始 — エンジンが指定した曲名・開始時刻で同期再生（同室複数端末対応）
      setTimeout(() => {
        const onEnd = () => { if (O.phase === 'discuss') wsSend({type:'music_ended'}); };
        if (data.song && data.songStarted) {
          playMusicSync(data.song, data.songStarted, onEnd);
        } else {
          playMusic(_pickSong(), onEnd);
        }
        // ── スマホ音楽ブロック対策: 3秒後に再生できていなければ90秒フォールバック ──
        setTimeout(() => {
          if (O.phase !== 'discuss' || (bgmAudio && !bgmAudio.paused)) return;
          // 音楽が流れていない → 一定時間後に自動で music_ended を送信
          if (!O._musicFailTimer) {
            O._musicFailTimer = setTimeout(() => {
              O._musicFailTimer = null;
              if (O.phase === 'discuss') wsSend({type:'music_ended'});
            }, 90 * 1000); // 90秒後に強制進行
          }
        }, 3000);
      }, 650);
      break;
    case 'disc_new_round':
      O.discRound = data.round; O.currentSpeaker = null; break;
    case 'disc_turn':
      O.currentSpeaker = data.name; O.isMyDiscTurn = false; O.tplStep = null; break;
    case 'your_disc_turn':
      O.isMyDiscTurn = true; O.tplStep = 'cat'; O.tplTarget = null; break;
    case 'disc_message':
      O.discMsgs.push({name: data.name, text: data.text});
      // カミングアウト自動検出（占い師・騎士・霊媒師・猫又キーワード）
      if (!O.deadPlayers.find(d=>d.name===data.name)) {
        const seerKw   = ['占い師','占いまし','占い結果','占った','黒でした','白でした','人狼です！','人狼ではありません'];
        const docKw    = ['騎士','護衛','守りまし'];
        const medKw    = ['霊媒師','霊媒','霊視','処刑された','処刑者の役職'];
        const nekoKw   = ['猫又','道連れ','ねこまた'];
        if      (seerKw.some(kw=>data.text.includes(kw)))                           O.roleClaims[data.name] = 'SEER';
        else if (docKw.some(kw=>data.text.includes(kw)) && !O.roleClaims[data.name]) O.roleClaims[data.name] = 'DOCTOR';
        else if (medKw.some(kw=>data.text.includes(kw)) && !O.roleClaims[data.name]) O.roleClaims[data.name] = 'MEDIUM';
        else if (nekoKw.some(kw=>data.text.includes(kw)) && !O.roleClaims[data.name]) O.roleClaims[data.name] = 'NEKOMATA';
      }
      O.currentSpeaker = null; break;
    case 'day_start':
      O.eliminatedLastNight = data.eliminated; O.alive = data.alive;
      O.phase = 'day'; break;
    case 'vote_ready_upd':
      O.voteReadyNames = data.readyNames || []; break;
    case 'vote_ready_all':
      O.voteReadyAll = true;
      fadeOutMusic(1700);
      break;
    case 'vote_start':
      stopMusic(); // 議論BGMを停止
      if (O._musicFailTimer) { clearTimeout(O._musicFailTimer); O._musicFailTimer = null; }
      O.alive = data.alive; O.voteSubmitted = false;
      O.voteDone = 0; O.voteTotal = data.alive.length;
      O.voteResult = null; O.phase = 'vote'; break;
    case 'vote_progress':
      O.voteDone = data.done; O.voteTotal = data.total; break;
    case 'medium_reveal':
      // 霊媒師のみに届く: 処刑された人の役職を記録
      O.mediumReveal = { target: data.target, role: data.role };
      break;
    case 'vote_result':
      O.voteResult = {executed: data.executed, role: data.executed_role, tally: data.tally, nekomataVictim: data.nekomata_victim};
      O.winner = data.winner;
      if (data.players && data.players.length > 0) {
        O.finalPlayers = data.players.map(p => ({
          name: p.name || '?',
          role: p.role || undefined,
          alive: !!p.alive,
        }));
        O.log = data.log || [];
      }
      // 処刑された人を死亡リストへ（役職は内部保持のみ、表示はしない）
      if (data.executed) {
        const av = getAvatar(data.executed, O.players);
        if (!O.deadPlayers.find(d=>d.name===data.executed))
          O.deadPlayers.push({ name:data.executed, role:data.executed_role, avatar:av, day:O.day, cause:'処刑' });
        delete O.roleClaims[data.executed];
      }
      // 猫又の道連れを死亡リストへ
      if (data.nekomata_victim) {
        const av2 = getAvatar(data.nekomata_victim, O.players);
        if (!O.deadPlayers.find(d=>d.name===data.nekomata_victim))
          O.deadPlayers.push({ name:data.nekomata_victim, role:null, avatar:av2, day:O.day, cause:'猫又' });
        if (O.alive) O.alive = O.alive.filter(p=>p.name!==data.nekomata_victim);
      }
      O.phase = 'vote_result'; break;
    case 'game_over':
      O.winner = data.winner;
      // data.players が null/undefined の場合は既存の finalPlayers を保持（フォールバック）
      if (data.players && data.players.length > 0) {
        // role が欠落しているプレイヤーがいても表示が壊れないよう保護
        O.finalPlayers = data.players.map(p => ({
          name: p.name || '?',
          role: p.role || undefined,
          alive: !!p.alive,
        }));
      }
      O.log = data.log || []; O.eliminatedLastNight = data.eliminated;
      O.phase = 'game_over';
      if (['solo','p2p','online'].includes(mode)) scoreGame();
      setTimeout(() => spawnConfetti(
        data.winner==='village' ? '#4ade8088' : '#ef444488',
        data.winner==='village' ? '#fbbf2488' : '#f8717188'
      ), 300);
      break;
    case 'error':
      alert(data.msg || data.message); return;
  }
  render();
}

// ========== ONLINE RENDERS ==========
function renderOnline() {
  switch(O.phase) {
    case 'setup':      return renderOSetup();
    case 'lobby':      return renderOLobby();
    case 'role':       return renderORole();
    case 'wolf_chat':  return renderOWolfChat();
    case 'night':      return renderONight();
    case 'discuss':    return renderODiscuss();
    case 'day':        return renderODay();
    case 'vote':       return renderOVote();
    case 'vote_result':return renderOVoteResult();
    case 'game_over':  return renderOGameOver();
    default: return '';
  }
}


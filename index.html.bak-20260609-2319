<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>🐺 人狼ゲーム</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: linear-gradient(160deg, #0d0d1a 0%, #16213e 60%, #0f3460 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Segoe UI', sans-serif;
  color: #e2e8f0;
}
#app {
  max-width: 480px;
  margin: 0 auto;
  padding: 1rem 1rem 3rem;
  min-height: 100vh;
  animation: fadeIn 0.25s ease;
}
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* Typography */
h1 { font-size: 2rem; font-weight: 800; }
h2 { font-size: 1.4rem; font-weight: 700; }
h3 { font-size: 1.1rem; font-weight: 600; }
p  { line-height: 1.6; }

/* Divider */
.div { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 1.2rem 0; }

/* Section label */
.sec-label {
  color: #64748b;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 600;
  margin: 1.2rem 0 0.5rem;
}

/* Cards */
.card {
  background: rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 1.2rem;
  border: 1px solid rgba(255,255,255,0.1);
  margin: 0.6rem 0;
}
.card-colored {
  border-radius: 14px;
  padding: 1.2rem;
  margin: 0.6rem 0;
}

/* Buttons */
.btn {
  display: block;
  width: 100%;
  padding: 0.85rem 1rem;
  border: none;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  margin: 0.5rem 0;
  transition: opacity 0.15s, transform 0.1s;
  letter-spacing: 0.02em;
}
.btn:active { transform: scale(0.97); opacity: 0.85; }
.btn-primary { background: linear-gradient(135deg, #6b21a8, #4338ca); color: #fff; }
.btn-danger  { background: linear-gradient(135deg, #7f1d1d, #7c3aed); color: #fff; }
.btn-success { background: linear-gradient(135deg, #064e3b, #0369a1); color: #fff; }
.btn-night   { background: rgba(99,102,241,0.15); color: #a5b4fc; border: 1px solid #4338ca; }
.btn-ghost   { background: rgba(255,255,255,0.06); color: #94a3b8; border: 1px solid rgba(255,255,255,0.1); }

/* Phase header */
.ph {
  text-align: center;
  padding: 1.5rem 0 0.5rem;
}
.ph .icon { font-size: 3rem; margin-bottom: 0.3rem; }
.ph h1 { margin: 0.2rem 0; }
.ph .sub { color: #64748b; font-size: 0.95rem; margin: 0; }

/* Inputs */
input[type="text"], select {
  width: 100%;
  padding: 0.65rem 0.9rem;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 9px;
  color: #e2e8f0;
  font-size: 0.95rem;
  margin: 0.25rem 0 0.5rem;
  outline: none;
  transition: border-color 0.15s;
}
input[type="text"]:focus, select:focus { border-color: #6b21a8; }
select option { background: #1e1b4b; }
label { color: #94a3b8; font-size: 0.85rem; display: block; margin-bottom: 0.15rem; }

/* Player name grid */
.name-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 0.6rem; }
.name-grid .name-item input { font-size: 0.9rem; }

/* Role counter grid */
.role-grid { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.role-item {
  flex: 1;
  min-width: 70px;
  text-align: center;
  padding: 0.7rem 0.4rem;
  background: rgba(255,255,255,0.05);
  border-radius: 10px;
}
.role-item .ri { font-size: 1.6rem; }
.role-item .rc { font-size: 1.4rem; font-weight: 800; }
.role-item .rn { font-size: 0.75rem; color: #94a3b8; }

/* Count control */
.count-ctrl {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  margin: 0.5rem 0;
}
.cnt-btn {
  width: 46px; height: 46px;
  border-radius: 50%;
  background: rgba(255,255,255,0.09);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
  font-size: 1.5rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  user-select: none;
  transition: background 0.15s;
}
.cnt-btn:active { background: rgba(255,255,255,0.18); }
.cnt-val { font-size: 2.8rem; font-weight: 800; color: #fff; min-width: 64px; text-align: center; }

/* Role reveal card */
.role-reveal-card {
  text-align: center;
  padding: 2.2rem 1.5rem;
  border-radius: 18px;
  border: 2px solid;
  margin: 1rem 0;
}
.rrc-icon { font-size: 5rem; margin: 0.5rem 0; }
.rrc-name { font-size: 2.6rem; font-weight: 900; margin: 0.2rem 0; }
.rrc-team { font-size: 0.85rem; color: #94a3b8; }
.rrc-desc { font-size: 0.92rem; color: #cbd5e1; margin-top: 0.9rem; line-height: 1.65; }
.rrc-tips { text-align:left; background:rgba(0,0,0,.28); border-radius:12px; padding:.75rem 1rem; margin-top:.9rem; }
.rrc-tips-title { font-size:.76rem; font-weight:700; color:#94a3b8; letter-spacing:.07em; margin-bottom:.5rem; }
.rrc-tips-item { font-size:.82rem; color:#b0bec5; line-height:1.65; padding:.1rem 0 .1rem 1.2rem; position:relative; }
.rrc-tips-item::before { content:'💡'; position:absolute; left:0; }
/* 人狼仲間バー */
.wolf-ally-bar { display:flex; align-items:center; flex-wrap:wrap; gap:.45rem;
  background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.3);
  border-radius:10px; padding:.5rem .85rem; margin-bottom:.6rem; font-size:.83rem; }
.wolf-ally-label { color:#f87171; font-weight:700; white-space:nowrap; }
.wolf-ally-chip { background:rgba(239,68,68,.18); color:#fca5a5; border-radius:20px;
  padding:.15rem .6rem; font-size:.8rem; }

/* Chips */
.chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.4rem 0; }
.chip {
  padding: 0.3rem 0.75rem;
  border-radius: 20px;
  font-size: 0.88rem;
  background: rgba(255,255,255,0.09);
  color: #e2e8f0;
}

/* Player row (game over) */
.player-row {
  display: flex;
  align-items: center;
  padding: 0.6rem 1rem;
  background: rgba(255,255,255,0.04);
  border-radius: 10px;
  margin: 0.3rem 0;
  border-left: 4px solid;
}
.pr-icon { font-size: 1.3rem; margin-right: 0.7rem; }
.pr-name { flex: 1; font-weight: 600; }
.pr-role { font-size: 0.85rem; margin-right: 0.8rem; }
.pr-status { font-size: 0.8rem; color: #475569; }

/* Vote bar */
.vote-bar { font-family: 'Courier New', monospace; font-size: 0.88rem; margin: 0.3rem 0; color: #94a3b8; }
.vote-bar.executed { color: #f87171; font-weight: 700; }

/* Progress text */
.progress { text-align: center; color: #475569; font-size: 0.85rem; margin: 0.4rem 0; }

/* Pass screen */
.pass-screen {
  text-align: center;
  padding: 2rem 1.5rem;
  border-radius: 14px;
  border: 1px solid;
  margin: 0.8rem 0;
}
.pass-screen h3 { margin: 0 0 0.5rem; }
.pass-screen h2 { color: #fff; margin: 0.3rem 0; }
.pass-screen .hint { color: #475569; font-size: 0.85rem; margin: 0; }

/* Log */
details summary { color: #64748b; cursor: pointer; padding: 0.5rem 0; font-size: 0.9rem; }
details summary:hover { color: #94a3b8; }
.log-entry { color: #64748b; font-size: 0.83rem; padding: 0.2rem 0 0.2rem 0.5rem; border-left: 2px solid rgba(255,255,255,0.08); margin: 0.2rem 0; }
/* Chat feed */
.chat-feed {
  max-height: 260px; overflow-y: auto;
  background: rgba(0,0,0,0.25); border-radius: 12px;
  padding: 0.7rem; margin: 0.5rem 0;
  scroll-behavior: smooth;
}
.chat-msg { margin: 0.35rem 0; padding: 0.45rem 0.7rem; background: rgba(255,255,255,0.06); border-radius: 8px; }
.chat-name { color: #818cf8; font-weight: 700; font-size: 0.82rem; margin-right: 0.45rem; }
.chat-text { color: #e2e8f0; font-size: 0.9rem; }
.chat-typing { color: #475569; font-size: 0.78rem; padding: 0.3rem 0.6rem; font-style: italic; }
.wolf-msg { background: rgba(239,68,68,0.1); border-left: 3px solid #ef444488; }
.wolf-msg .chat-name { color: #f87171; }
/* ── Opening Story ── */
.story-overlay{position:fixed;inset:0;background:#050510;z-index:1000;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;}
.story-moon{font-size:4.5rem;margin-bottom:1.5rem;}
.story-text{color:#c8d8f4;font-size:1.1rem;line-height:2;max-width:380px;min-height:4rem;transition:opacity .4s ease;}
.story-cursor{display:inline-block;width:2px;height:1em;background:#a5b4fc;margin-left:2px;vertical-align:middle;opacity:.7;}
.story-progress{width:180px;height:3px;background:rgba(255,255,255,.08);border-radius:2px;margin-top:1.2rem;overflow:hidden;}
.story-progress-bar{height:100%;background:linear-gradient(90deg,#6b21a8,#4338ca);transition:width .5s;}
.story-skip{margin-top:2rem;padding:.5rem 1.6rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:20px;color:#64748b;font-size:.82rem;cursor:pointer;transition:color .2s;}
.story-skip:hover{color:#94a3b8;}

/* ── Kill Drama Overlay ── */
.kill-overlay{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:900;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;animation:killFadeIn .5s ease;}
@keyframes killFadeIn{from{opacity:0;}to{opacity:1;}}
.kill-icon{font-size:5rem;}
.kill-title{color:#ef4444;font-size:.9rem;font-weight:700;letter-spacing:.12em;margin-bottom:.4rem;margin-top:1.2rem;}
.kill-name{font-size:2.5rem;font-weight:900;color:#fff;margin:.2rem 0;}
.kill-role{color:#94a3b8;font-size:1.05rem;}
.kill-tap{color:#475569;font-size:.8rem;margin-top:1.8rem;}

/* ── Confetti ── */
.confetti-wrap{position:fixed;inset:0;pointer-events:none;z-index:800;overflow:hidden;}
.cp{position:absolute;width:9px;height:9px;border-radius:2px;animation:cpFall linear forwards;}
@keyframes cpFall{from{transform:translateY(-20px) rotate(0deg);opacity:1;}to{transform:translateY(110vh) rotate(720deg);opacity:.1;}}

/* ── P2P badge ── */
.p2p-badge{display:inline-flex;align-items:center;gap:.3rem;background:rgba(16,185,129,.14);border:1px solid #10b98144;border-radius:6px;padding:.15rem .5rem;font-size:.74rem;color:#34d399;margin-left:.3rem;}
.p2p-dot{width:6px;height:6px;border-radius:50%;background:#34d399;animation:p2pPulse 1.5s ease-in-out infinite;}
@keyframes p2pPulse{0%,100%{opacity:1;}50%{opacity:.2;}}

/* ── Wolf Secret Chat ── */
.secret-bar{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:.6rem 1rem;margin-bottom:.7rem;text-align:center;}
.secret-tag{display:inline-flex;align-items:center;gap:.3rem;background:rgba(239,68,68,.2);border-radius:16px;padding:.2rem .7rem;font-size:.76rem;color:#f87171;font-weight:700;}

/* ── Animations ── */
@keyframes roleReveal{from{opacity:0;}to{opacity:1;}}
.role-reveal-card{animation:roleReveal .4s ease;}
@keyframes voteDrama{from{opacity:0;}to{opacity:1;}}
.vote-drama{animation:voteDrama .4s ease;}
@keyframes phaseIn{from{opacity:0;}to{opacity:1;}}
#app>*{animation:phaseIn .2s ease;}

/* ── Character Avatars ── */
.avatar-grid{display:flex;flex-wrap:wrap;gap:.5rem;margin:.4rem 0;}
.avatar-card{display:flex;flex-direction:column;align-items:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:.6rem .4rem;min-width:72px;max-width:80px;cursor:pointer;transition:background .15s;}
.avatar-card:hover{background:rgba(255,255,255,.12);}
.avatar-card.selected{border:2px solid #6b21a8;background:rgba(107,33,168,.15);}
.avatar-card.dead{opacity:.4;filter:grayscale(1);}
.av-emoji{font-size:2.2rem;line-height:1;}
.av-label{font-size:.72rem;color:#94a3b8;font-weight:600;margin-top:.2rem;text-align:center;}
.av-hint{font-size:.62rem;color:#475569;margin-top:.1rem;text-align:center;line-height:1.3;}
.av-status{font-size:.65rem;margin-top:.2rem;text-align:center;}

/* ── Role Claim Badge ── */
.claim-badge{display:inline-flex;align-items:center;gap:.2rem;font-size:.72rem;padding:.1rem .4rem;border-radius:10px;margin-left:.3rem;font-weight:700;}
.claim-unverified{background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid #fbbf2433;}
.claim-confirmed{background:rgba(129,140,248,.2);color:#a5b4fc;border:1px solid #818cf855;}
.claim-dead-wolf{background:rgba(239,68,68,.2);color:#f87171;border:1px solid #ef444455;}

/* ── Death List ── */
.death-list{background:rgba(0,0,0,.3);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:.7rem .8rem;margin:.5rem 0;}
.death-entry{display:flex;align-items:center;gap:.5rem;padding:.3rem 0;border-bottom:1px solid rgba(255,255,255,.04);}
.death-entry:last-child{border-bottom:none;}
.de-avatar{font-size:1.4rem;}
.de-name{flex:1;font-size:.88rem;font-weight:600;color:#94a3b8;text-decoration:line-through;}
.de-role{font-size:.8rem;}

/* ── Chat Message with Avatar ── */
.chat-msg{margin:.4rem 0;padding:.5rem .7rem;background:rgba(255,255,255,.06);border-radius:8px;display:flex;align-items:flex-start;gap:.5rem;}
.cm-av{font-size:1.4rem;flex-shrink:0;line-height:1;}
.cm-body{flex:1;}
.cm-name{color:#818cf8;font-weight:700;font-size:.82rem;}
.cm-text{color:#e2e8f0;font-size:.9rem;margin-top:.1rem;}
.wolf-msg{background:rgba(239,68,68,.1);border-left:3px solid #ef444488;}
.wolf-msg .cm-name{color:#f87171;}
.seer-claim-msg{background:rgba(129,140,248,.1);border-left:3px solid #818cf888;}
.my-msg{background:rgba(99,102,241,.12);border-left:3px solid #6b21a8;}

/* Template picker */
.tpl-cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem; margin: 0.5rem 0; }
.tpl-cat { padding: 0.75rem 0.5rem; background: rgba(99,102,241,0.13); border: 1px solid #4338ca55;
  border-radius: 10px; color: #a5b4fc; font-size: 0.9rem; cursor: pointer; text-align: center; }
.tpl-cat:active { background: rgba(99,102,241,0.28); }
.tpl-btn { display: block; width: 100%; padding: 0.7rem 1rem; margin: 0.3rem 0;
  background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; color: #e2e8f0; font-size: 0.9rem; cursor: pointer; text-align: left; }
.tpl-btn:active { background: rgba(255,255,255,0.16); }
.tpl-section-label { color: #64748b; font-size: 0.78rem; margin: 0.8rem 0 0.3rem; }
.cpu-badge { font-size: 0.7rem; background: rgba(99,102,241,0.2); color: #818cf8;
  border-radius: 4px; padding: 0.1rem 0.35rem; margin-left: 0.3rem; }
/* ── Music indicator ── */
.music-bar{background:rgba(251,191,36,.1);border:1px solid #fbbf2433;border-radius:10px;padding:.4rem .8rem;display:flex;align-items:center;gap:.5rem;margin:.3rem 0;}
@keyframes musicPulse{0%,100%{opacity:1;}50%{opacity:.25;}}
/* ── Free chat input bar ── */
.free-chat-bar{display:flex;gap:.35rem;margin:.35rem 0;}
.free-chat-bar input{flex:1;min-width:0;padding:.55rem .7rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:9px;color:#e2e8f0;font-size:.9rem;outline:none;}
.free-chat-bar input:focus{border-color:#6b21a8;}
.free-chat-bar input::placeholder{color:#475569;}
.free-chat-bar .send-btn{padding:.55rem .9rem;border:none;border-radius:9px;background:linear-gradient(135deg,#6b21a8,#4338ca);color:#fff;font-size:.88rem;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0;}
.free-chat-bar .send-btn:active{opacity:.8;}
/* ── Quick agree button ── */
.quick-agree{background:rgba(99,102,241,.18);border:1px solid #4338ca55;color:#a5b4fc;font-size:.66rem;padding:.1rem .32rem;border-radius:6px;cursor:pointer;margin-left:.3rem;vertical-align:middle;line-height:1.4;}
.quick-agree:active{background:rgba(99,102,241,.38);}
/* ── Vote Ready Bar ── */
.vote-ready-bar{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:.55rem .7rem;margin:.45rem 0;}
.vote-ready-bar.all-ready{background:rgba(34,197,94,.12);border-color:#22c55e88;animation:musicPulse .9s ease-in-out infinite;}
.vote-ready-btn{flex:1;padding:.6rem .8rem;border:none;border-radius:9px;font-size:.88rem;font-weight:700;cursor:pointer;transition:opacity .15s,transform .1s;}
.vote-ready-btn:active{transform:scale(.96);}
.vote-ready-btn.ready{background:rgba(34,197,94,.18);border:1px solid #22c55e55;color:#4ade80;cursor:default;}
.vote-ready-btn.not-ready{background:linear-gradient(135deg,#065f46,#0369a1);color:#fff;}
.vote-ready-dots{display:flex;gap:.25rem;flex-wrap:wrap;margin-top:.3rem;}
/* ── CO quick button ── */
.co-quick-btns{display:flex;flex-wrap:wrap;gap:.3rem;margin:.3rem 0;}
.co-btn{display:inline-flex;align-items:center;gap:.2rem;background:rgba(129,140,248,.14);border:1px solid #818cf855;color:#a5b4fc;font-size:.78rem;padding:.28rem .6rem;border-radius:8px;cursor:pointer;}
.co-btn:active{background:rgba(129,140,248,.3);}
/* ── Stealth night target grid ── */
.night-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem;margin:1rem 0;}
.night-card{position:relative;background:rgba(255,255,255,.05);border:2px solid rgba(255,255,255,.08);border-radius:14px;padding:.9rem .4rem;text-align:center;cursor:pointer;transition:border-color .15s,background .15s;}
.night-card:active{transform:scale(.95);}
.night-card.selected{border-color:#6b21a8;background:rgba(107,33,168,.18);}
.night-card .nc-emoji{font-size:2.2rem;line-height:1;margin-bottom:.3rem;}
.night-card .nc-name{font-size:.78rem;color:#94a3b8;font-weight:600;word-break:break-all;}
.night-card .nc-check{position:absolute;top:.3rem;right:.35rem;font-size:.9rem;opacity:0;}
.night-card.selected .nc-check{opacity:1;}
/* ── Progression / Detective Rank ── */
.levelup-banner{background:linear-gradient(135deg,#6b21a8,#4338ca);color:#fff;text-align:center;font-weight:800;padding:.7rem;border-radius:12px;margin:.5rem 0;animation:musicPulse 1.4s ease-in-out infinite;box-shadow:0 0 24px #6b21a866;}
.note-btn{display:flex;align-items:center;gap:.5rem;width:100%;text-align:left;border-radius:9px;padding:.4rem .6rem;margin:.2rem 0;color:#e2e8f0;cursor:pointer;transition:border-color .15s,background .15s;}
.xp-bar{background:rgba(255,255,255,.08);border-radius:8px;height:10px;overflow:hidden;margin:.35rem 0;}
.xp-bar > div{height:100%;background:linear-gradient(90deg,#6b21a8,#818cf8);transition:width .8s ease;}
@keyframes scorePop{0%{transform:scale(.6);opacity:0;}60%{transform:scale(1.12);}100%{transform:scale(1);opacity:1;}}
.score-pop{animation:scorePop .5s ease;}
</style>
</head>
<body>
<div id="app"></div>
<script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js" onerror="window._peerJsFailed=true"></script>
<script>
// ========== CHARACTER AVATARS ==========
const CHARACTER_AVATARS = [
  { emoji:'🧙‍♂️', label:'老魔術師',   hint:'謎に包まれた老人…何か知っていそう' },
  { emoji:'🕵️',   label:'かげろう',   hint:'鋭い目つきの調査員。信用できる？' },
  { emoji:'🧛',   label:'ドラクール', hint:'怪しい雰囲気の貴族…人狼では？' },
  { emoji:'👨‍🌾',  label:'のどか',    hint:'普通の農夫に見えるが…' },
  { emoji:'🦹‍♀️', label:'シャドウ',  hint:'影のある女性。何かを隠している？' },
  { emoji:'🧝‍♀️', label:'エルファ',  hint:'神秘的な森の住人。占い師かも' },
  { emoji:'👮‍♂️', label:'田中巡査',  hint:'真面目そうな顔だが…' },
  { emoji:'🧟',   label:'ゾンビ',    hint:'生気のない目。何があった？' },
  { emoji:'🧜‍♀️', label:'ナミ',     hint:'不思議な雰囲気。本当の姿は？' },
  { emoji:'🦸‍♂️', label:'ブレイブ',  hint:'正義感の強い青年。騎士かも' },

}

// ========== P2P SETUP SCREEN ==========
function renderP2PSetup() {
  const sub = O.p2pSub || 'choose';
  if (sub === 'host_wait') {
    const pRows = (O.players||[]).map(p=>`<span class="chip">${esc(p.name)}</span>`).join('');
    const total = (O.players||[]).length + (O.cpuCount||0);
    const canStart = total >= 4;
    return `
      ${ph('🌐','ホスト待機中','部屋コードを仲間に伝えてください','#34d399')}
      <div class="card" style="text-align:center;border:2px solid #059669;padding:1.5rem;">
        <p style="color:#64748b;font-size:.85rem;margin-bottom:.4rem;">🔑 部屋コード（仲間に伝える）</p>
        <div style="font-size:3rem;font-weight:900;letter-spacing:.3em;color:#34d399;">${O.roomCode||'----'}</div>
        <p class="p2p-badge" style="justify-content:center;margin-top:.5rem;"><span class="p2p-dot"></span>接続待ち...</p>
      </div>
      <p class="sec-label">👥 参加中 (${(O.players||[]).length}人)</p>
      <div class="chips">${pRows||'<span style="color:#475569;font-size:.85rem;">まだ誰もいません</span>'}</div>
      <p class="sec-label">🤖 CPUプレイヤー人数</p>
      <div class="count-ctrl">
        <button class="cnt-btn" id="oCpuDec">−</button>
        <div class="cnt-val" style="font-size:2rem;">${O.cpuCount||0}</div>
        <button class="cnt-btn" id="oCpuInc">＋</button>
      </div>
      <p style="color:#475569;font-size:.8rem;text-align:center;margin-bottom:.5rem;">合計 ${total}人でゲーム（4人以上必要）</p>
      <hr class="div">
      ${canStart
        ? `<button class="btn btn-success" id="p2pStartGame">🎮　ゲームスタート！(計${total}人)</button>`
        : `<div class="card" style="text-align:center;"><p style="color:#64748b;">合計4人以上必要です（現在${total}人）</p></div>`}
      <button class="btn btn-ghost" id="goHome" style="margin-top:.5rem;">← ホームへ戻る</button>`;
  }
  if (sub === 'guest_wait') {
    return `
      ${ph('🌐','P2P接続中','ホストへ接続しています...','#34d399')}
      <div class="card" style="text-align:center;">
        <div style="font-size:2.5rem;margin-bottom:.5rem;">⏳</div>
        <p style="color:#64748b;">ホストへの接続を待っています</p>
        <p class="p2p-badge" style="justify-content:center;margin-top:.5rem;"><span class="p2p-dot"></span>接続中</p>
      </div>
      <button class="btn btn-ghost" id="goHome">← キャンセル</button>`;
  }
  const isJoin = sub === 'join';
  return `
    ${ph('🌐','P2Pオンライン','サーバー不要でどこからでも対戦！','#34d399')}
    <div class="card">
      <label>あなたの名前</label>
      <input type="text" id="p2pName" value="${esc(O.playerName||'')}" placeholder="名前を入力">
    </div>
    ${isJoin ? `
      <div class="card">
        <label>部屋コード（ホストに聞く）</label>
        <input type="text" id="p2pCode" placeholder="例: 12345" style="letter-spacing:.25em;font-size:1.8rem;text-align:center;" maxlength="5" inputmode="numeric">
        <button class="btn btn-success" id="p2pJoin" style="margin-top:.6rem;">🚪　参加する</button>
      </div>
      <button class="btn btn-ghost" id="p2pBackSetup">← 戻る</button>
    ` : `
      <button class="btn btn-success" id="p2pCreate">🏠　部屋を作る（ホスト）</button>
      <button class="btn btn-night" id="p2pGoJoin">🚪　部屋に参加する</button>
      <button class="btn btn-ghost" id="goHome">← ホームへ戻る</button>
    `}
    <div class="card" style="background:rgba(52,211,153,.05);border:1px solid #05966944;margin-top:.8rem;">
      <p style="color:#34d399;font-size:.83rem;font-weight:700;margin-bottom:.3rem;">📡 P2Pオンラインとは？</p>
      <p style="color:#475569;font-size:.8rem;line-height:1.65;">インターネット経由でどこからでも対戦できます。ホストが部屋を作り、仲間にコードを伝えるだけ。人数が足りない場合はCPUを追加できます。</p>
    </div>`;
}

// ========== SOLO SETUP SCREEN ==========
function renderSoloSetup() {
  const total = O.soloTotal || 5;
  const roleNames = (CONFIGS[total]||[]).map(r=>ROLES[r]?.name||r).join('・');
  const diff = O.soloDiff || 'normal';
  const s = PROGRESS.summary();
  const diffBtns = ['easy','normal','hard'].map(d=>{
    const cur = diff===d;
    const lbl = d==='easy'?'やさしい':d==='normal'?'ふつう':'むずかしい';
    const mult = d==='easy'?'XP×0.8':d==='normal'?'XP×1.0':'XP×1.3';
    return `<button id="soloDiff_${d}" style="flex:1;padding:.5rem .3rem;border-radius:9px;border:1px solid ${cur?'#6b21a8':'rgba(255,255,255,.14)'};background:${cur?'rgba(107,33,168,.25)':'rgba(255,255,255,.05)'};color:${cur?'#c4b5fd':'#94a3b8'};font-size:.82rem;font-weight:700;cursor:pointer;line-height:1.3;">${lbl}<br><span style="font-size:.64rem;color:#64748b;">${mult}</span></button>`;
  }).join('');
  return `
    ${ph('🎮','ソロデモモード','CPUと対戦して探偵ランクを上げよう！','#34d399')}
    <div style="text-align:center;font-size:.8rem;color:#94a3b8;margin:.1rem 0 .5rem;">
      ${s.info.rank.icon} ${s.info.rank.name} Lv.${s.info.level}　・　📅 ${s.dailyDone?'<span style="color:#4ade80;">デイリー達成✅</span>':esc(s.mission.label)}
    </div>
    <div class="card">
      <label>あなたの名前</label>
      <input type="text" id="soloName" value="${esc(O.playerName||'')}" placeholder="名前を入力（例：たろう）">
      <label style="margin-top:0.9rem;">プレイヤー人数（あなた＋CPU）</label>
      <div class="count-ctrl">
        <button class="cnt-btn" id="soloDec">−</button>
        <div class="cnt-val">${total}</div>
        <button class="cnt-btn" id="soloInc">＋</button>
      </div>
      <p style="color:#475569; font-size:0.8rem; text-align:center; margin-bottom:0.4rem;">
        あなた1人 ＋ CPU ${total-1}人
      </p>
      <p style="color:#64748b; font-size:0.78rem; text-align:center; margin-bottom:0.7rem;">
        役職構成：${roleNames}
      </p>
      <label>難易度（CPUの賢さ・獲得XPに影響）</label>
      <div style="display:flex;gap:.4rem;margin:.2rem 0 .8rem;">${diffBtns}</div>
      <button class="btn btn-success" id="soloStart">🎮　ゲームスタート！</button>
    </div>
    <div class="card" style="background:rgba(52,211,153,0.05); border:1px solid #05966944;">
      <p style="color:#34d399; font-size:0.85rem; font-weight:700; margin-bottom:0.4rem;">🎮 ソロデモモードとは？</p>
      <p style="color:#475569; font-size:0.82rem; line-height:1.65;">
        あなた1人でCPUプレイヤーと一緒に人狼ゲームを体験できます。<br>
        役職・夜の行動・議論・投票をすべてブラウザ内で再現。<br>
        サーバー不要なのでGitHub Pagesでも動作します。
      </p>
    </div>
    <button class="btn btn-ghost" id="goHome">← ホームへ戻る</button>
  `;
}

// ========== UPDATED RENDER ==========
function render() {
  const app = document.getElementById('app');
  // チャット入力中のテキストを保持（CPUターンで再描画されても消えないように）
  const _discVal  = document.getElementById('discFreeInput')?.value  || '';
  const _wolfVal  = document.getElementById('wolfFreeInput')?.value  || '';

  if      (mode === 'pre_opening')                         app.innerHTML = renderPreOpening();
  else if (mode === 'opening')                             app.innerHTML = renderOpening();
  else if (mode === 'home')                                app.innerHTML = renderHome();
  else if (mode === 'codex')                               app.innerHTML = renderCodex();
  else if (mode === 'local')                               app.innerHTML = renderPhase();
  else if (mode === 'solo' && O.phase === 'solo_setup')    app.innerHTML = renderSoloSetup();
  else if (mode === 'p2p'  && O.phase === 'p2p_setup')    app.innerHTML = renderP2PSetup();
  else                                                     app.innerHTML = renderOnline();

  // 入力値を復元
  const discInput = document.getElementById('discFreeInput');
  if (discInput && _discVal) { discInput.value = _discVal; }
  const wolfInput = document.getElementById('wolfFreeInput');
  if (wolfInput && _wolfVal) { wolfInput.value = _wolfVal; }

  // 議論・チャット中は画面トップに飛ばさない（上下スクロール防止）
  const chatPhases = ['discuss','wolf_chat'];
  if (!chatPhases.includes(O.phase)) window.scrollTo(0, 0);
  bindEvents();
  // チャットフィードを末尾にスクロール
  setTimeout(() => {
    ['discFeed','wolfFeed'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.scrollTop = el.scrollHeight;
    });
  }, 30);
}

function renderPhase() {
  switch (S.phase) {
    case 'setup':       return renderSetup();
    case 'role_reveal': return renderRoleReveal();
    case 'night':       return renderNight();
    case 'day':         return renderDay();
    case 'vote':        return renderVote();
    case 'vote_result': return renderVoteResult();
    case 'game_over':   return renderGameOver();
    default: return '';
  }
}

// ========== GLOBAL HELPERS (onclick属性から呼ばれる) ==========
// ローカルゲーム人狼ターゲット選択（ステルス）
function localWolfPick(name) {
  S._wolfLocalSel = name;
  render();
}
// 捜査ノート: 怪しい → 信用 → 未定 をトグル（ソロ専用）
function toggleNote(name) {
  if (!O.notebook) O.notebook = {};
  const cur = O.notebook[name];
  const next = cur===undefined ? 'suspect' : cur==='suspect' ? 'trust' : undefined;
  if (next===undefined) delete O.notebook[name]; else O.notebook[name] = next;
  render();
}
function wolfSend(text) {
  wsSend({type:'wolf_chat_msg', text});
  // ローカルにも追加して即表示
  O.wolfChatMsgs.push({name: O.playerName, text});
  render();
  setTimeout(() => { const f = document.getElementById('wolfFeed'); if(f) f.scrollTop = f.scrollHeight; }, 50);
}
function wolfTplTarget(idx) {
  const t = TPL.wolf_night[idx];
  const targets = O.wolfChatMsgs.length > 0
    ? O.alive.filter(p => p.name !== O.playerName)
    : O.alive.filter(p => p.name !== O.playerName);
  if (!targets.length) return;
  // 簡易的に最初のターゲットを選択するUIを表示
  const name = prompt('誰への発言ですか？\n' + targets.map(p=>p.name).join(' / '));
  if (!name) return;
  wolfSend(t.replace('{n}', name));
}

// ========== START ==========
let mode = 'pre_opening'; // pre_opening | opening | home | local | online | solo | p2p
initState();
render();
</script>

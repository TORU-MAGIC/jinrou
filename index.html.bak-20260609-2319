// ========== EVENTS ==========
function saveNames() {
  for (let i = 0; i < 15; i++) {
    const e = document.getElementById(`pn${i}`);
    if (e) S.playerNames[i] = e.value;
  }
}

function bindEvents() {
  // SETUP
  on('dec', () => { if (S.playerCount > 4) { saveNames(); S.playerCount--; render(); } });
  on('inc', () => { if (S.playerCount < 15) { saveNames(); S.playerCount++; render(); } });
  on('start', () => {
    saveNames();
    const names = S.playerNames.slice(0, S.playerCount).map(n => n.trim());
    if (names.some(n => !n))             return alert('名前をすべて入力してください');
    if (new Set(names).size !== names.length) return alert('プレイヤー名が重複しています');

    const roles = shuffle(CONFIGS[S.playerCount] || CONFIGS[6]);
    S.players = names.map((name, i) => ({name, role: roles[i], alive: true}));
    S.revealIdx = 0;
    S.revealShown = false;
    S.phase = 'role_reveal';
    render();
  });

  // ROLE REVEAL
  on('showRole', () => { S.revealShown = true; render(); });
  on('nextReveal', () => {
    S.revealIdx++;
    S.revealShown = false;
    if (S.revealIdx >= S.players.length) {
      S.day = 1;
      S.nightSteps = nightSteps();
      S.nightStepIdx = 0;
      S.nightSub = 'pass';
      S.phase = 'night';
    }
    render();
  });

  // NIGHT - seer
  on('seerReady', () => { S.nightSub = 'select'; render(); });
  on('seerConfirm', () => {
    const target = val('seerTgt');
    const tp = S.players.find(p => p.name === target);
    S.seerResult = {target, isWolf: tp.role === 'WEREWOLF'};
    S.seerHistory.push({day: S.day, ...S.seerResult});
    S.nightSub = 'result';
    render();
  });
  on('seerDone', () => {
    S.nightStepIdx++;
    S.nightSub = 'pass';
    S.seerResult = null;
    render();
  });

  // NIGHT - medium（霊媒師）
  on('mediumReady', () => { S.nightSub = 'select'; render(); });
  on('mediumDone',  () => { S.nightStepIdx++; S.nightSub = 'pass'; render(); });

  // NIGHT - doctor（連続護衛禁止）
  on('docReady',    () => { S.nightSub = 'select'; render(); });
  on('docConfirm',  () => {
    S.doctorTarget = val('docTgt');
    S.nightStepIdx++;
    S.nightSub = 'pass';
    render();
  });

  // NIGHT - wolf (ステルスグリッド)
  on('wolfReady',   () => { S.nightSub = 'select'; S._wolfLocalSel = null; render(); });
  on('wolfConfirm', () => {
    S.wolfTarget = S._wolfLocalSel || '';
    if (!S.wolfTarget) return;
    S._wolfLocalSel = null;
    S.nightStepIdx++;
    S.nightSub = 'pass';
    render();
  });

  // NIGHT - morning
  on('morning', () => {
    const wt = S.wolfTarget;
    const dt = S.doctorTarget;

    // 騎士護衛対象を記録（次夜の連続護衛禁止チェック用）
    if (dt) S.lastDoctorTarget = dt;

    if (wt && wt !== dt) {
      const victim = S.players.find(p => p.name === wt);
      if (victim) {
        victim.alive = false;
        S.elimLastNight = victim;
        log(`第${S.day}夜: ${wt} が人狼に襲われました`);
        // 猫又ルール: 猫又が夜に殺されると人狼を1人道連れ
        if (victim.role === 'NEKOMATA') {
          const wolves = S.players.filter(p => p.alive && p.role === 'WEREWOLF');
          if (wolves.length) {
            const dragged = wolves[Math.floor(Math.random()*wolves.length)];
            dragged.alive = false;
            log(`第${S.day}夜: 猫又の道連れで ${dragged.name}（人狼）も倒れました`);
          }
        }
      }
    } else {
      if (wt && wt === dt) log(`第${S.day}夜: 騎士が ${wt} を護衛しました！`);
      S.elimLastNight = null;
    }

    S.wolfTarget = null;
    S.doctorTarget = null;

    const w = checkWin();
    if (w) {
      S.winner = w;
      S.phase = 'game_over';
    } else {
      S.votes = {};
      S.voteIdx = 0;
      S.voteResult = null;
      S.phase = 'day';
    }
    render();
  });

  // DAY
  on('goVote', () => {
    S.votes = {};
    S.voteIdx = 0;
    S.voteResult = null;
    S.phase = 'vote';
    render();
  });

  // VOTE
  on('castVote', () => {
    const alivePl = alive();
    const voter = alivePl[S.voteIdx];
    S.votes[voter.name] = val('voteTgt');
    S.voteIdx++;

    if (S.voteIdx >= alivePl.length) {
      // Tally votes
      const tally = {};
      Object.values(S.votes).forEach(t => tally[t] = (tally[t]||0)+1);
      const maxV = Math.max(...Object.values(tally));
      const top = Object.keys(tally).filter(n => tally[n] === maxV);
      const executed = top[Math.floor(Math.random()*top.length)];
      const execP = S.players.find(p => p.name === executed);
      execP.alive = false;
      log(`第${S.day}日: ${executed} が処刑されました`); // 役職はゲームオーバー時に公開
      // 霊媒師用に処刑情報を記録
      S.lastExecuted = executed;
      S.lastExecutedRole = execP.role;
      // 猫又ルール: 処刑された場合、ランダムに生存者を1人道連れ
      let nekomataVictim = null;
      if (execP.role === 'NEKOMATA') {
        const bystanders = S.players.filter(p => p.alive && p.name !== executed);
        if (bystanders.length) {
          nekomataVictim = bystanders[Math.floor(Math.random()*bystanders.length)];
          nekomataVictim.alive = false;
          log(`第${S.day}日: 猫又の道連れで ${nekomataVictim.name} も倒れました`);
        }
      }
      S.voteResult = {executed, tally, nekomataVictim: nekomataVictim?.name};
      S.winner = checkWin();
      S.phase = 'vote_result';
    }
    render();
  });


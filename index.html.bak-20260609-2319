function renderTplPicker() {
  const step = O.tplStep;
  if (!step || step === 'cat') {
    const isSeer   = O.myRole === 'SEER';
    const isMedium = O.myRole === 'MEDIUM';
    const isDoctor = O.myRole === 'DOCTOR';
    const isNeko   = O.myRole === 'NEKOMATA';
    const isWolf   = O.myRole === 'WEREWOLF' || O.myRole === 'MADMAN';
    const coBtn = isSeer
      ? `<div style="grid-column:span 2;"><button class="tpl-cat" id="tCatSeer" style="width:100%;">🔮 占い情報を公開（CO）▶</button><p style="color:#475569;font-size:.7rem;text-align:center;margin:.2rem 0 0;">占い師として名乗り出て占い結果を伝える</p></div>`
      : isMedium
      ? `<div style="grid-column:span 2;"><button class="tpl-cat" id="tCatMedium" style="width:100%;">👁️ 霊媒結果を公開（CO）▶</button><p style="color:#475569;font-size:.7rem;text-align:center;margin:.2rem 0 0;">霊媒師としてCOして処刑者の役職を報告する</p></div>`
      : isDoctor
      ? `<div style="grid-column:span 2;"><button class="tpl-cat" id="tCatDoctor" style="width:100%;">💊 騎士としてCOする</button><p style="color:#475569;font-size:.7rem;text-align:center;margin:.2rem 0 0;">護衛役としてカミングアウトする</p></div>`
      : isNeko
      ? `<div style="grid-column:span 2;"><button class="tpl-cat" id="tCatNeko" style="width:100%;">🐱 猫又としてCOする</button><p style="color:#475569;font-size:.7rem;text-align:center;margin:.2rem 0 0;">道連れ能力をアピールしてCOする</p></div>`
      : isWolf
      ? `<div style="grid-column:span 2;"><button class="tpl-cat" id="tCatFakeCO" style="width:100%;border-color:#7c3aed55;background:rgba(124,58,237,.13);">🎭 役職を騙る（偽CO）▶</button><p style="color:#475569;font-size:.7rem;text-align:center;margin:.2rem 0 0;">占い師・霊媒師・騎士・猫又として偽りのCOをする</p></div>`
      : '';
    return `
      <div style="background:rgba(251,191,36,0.08); border:1px solid #fbbf2444; border-radius:12px; padding:1rem; margin-top:0.5rem;">
        <p style="color:#fbbf24; font-weight:700; font-size:0.9rem; margin-bottom:0.6rem;">👉 あなたの番です！発言を選んでください</p>
        <div class="tpl-cat-grid">
          <button class="tpl-cat" id="tCatNeutral">👀 様子を見る</button>
          <button class="tpl-cat" id="tCatAccuse">🔍 誰かを疑う ▶</button>
          <button class="tpl-cat" id="tCatDefend">✋ 弁護する</button>
          <button class="tpl-cat" id="tCatAgree">👍 同調する ▶</button>
          <button class="tpl-cat" id="tCatQuestion">❓ 質問する</button>
          <button class="tpl-cat" id="tCatPressure">⚡ 訴える</button>
          ${coBtn}
        </div>
      </div>`;
  }
  if (step === 'fake_co_pick') {
    return `
      <div style="background:rgba(124,58,237,.1); border:1px solid #7c3aed44; border-radius:12px; padding:1rem; margin-top:0.5rem;">
        <p style="color:#c4b5fd; font-weight:700; font-size:0.9rem; margin-bottom:0.6rem;">🎭 どの役職として偽COしますか？</p>
        <button class="tpl-btn" id="fakeSeerCO"   style="border-left:3px solid #818cf8;">🔮 占い師として偽CO ▶（対象を選ぶ）</button>
        <button class="tpl-btn" id="fakeMediumCO" style="border-left:3px solid #a78bfa;">👁️ 霊媒師として偽CO ▶（処刑者を選ぶ）</button>
        <button class="tpl-btn" id="fakeDoctorCO" style="border-left:3px solid #34d399;">💊 騎士として偽CO</button>
        <button class="tpl-btn" id="fakeNekoCO"   style="border-left:3px solid #fb923c;">🐱 猫又として偽CO</button>
        <button class="tpl-btn" id="tCatBack" style="color:#64748b; margin-top:0.5rem;">← 戻る</button>
      </div>`;
  }
  if (step === 'tgt_accuse' || step === 'tgt_agree' || step === 'tgt_seer' || step === 'tgt_medium') {
    const label = step === 'tgt_accuse' ? '🔍 誰を疑いますか？'
                : step === 'tgt_agree'  ? '👍 誰への同調ですか？'
                : step === 'tgt_seer'   ? '🔮 誰の占い結果ですか？'
                                        : '👁️ 誰の役職を報告しますか？（処刑された人）';
    // 霊媒師は死亡者から選ぶ、それ以外は生存者から
    const targets = step === 'tgt_medium'
      ? O.deadPlayers.map(d => ({ name: d.name }))
      : O.alive.filter(p => p.name !== O.playerName);
    const btns = targets.map(p =>
      `<button class="tpl-btn" id="tgt_${esc(p.name)}" data-step="${step}" data-name="${esc(p.name)}">${esc(p.name)}</button>`
    ).join('');
    return `
      <div style="background:rgba(251,191,36,0.08); border:1px solid #fbbf2444; border-radius:12px; padding:1rem; margin-top:0.5rem;">
        <p style="color:#fbbf24; font-weight:700; font-size:0.9rem; margin-bottom:0.6rem;">${label}</p>
        ${btns || '<p style="color:#475569;font-size:.8rem;">対象者がいません</p>'}
        <button class="tpl-btn" id="tCatBack" style="color:#64748b; margin-top:0.5rem;">← 戻る</button>
      </div>`;
  }
  // msg_* steps
  let templates = [];
  let heading = '💬 発言を選んでください';
  if      (step === 'msg_neutral')  templates = TPL.neutral;
  else if (step === 'msg_accuse')   templates = TPL.accuse.map(t => tplFill(t, O.tplTarget));
  else if (step === 'msg_defend')   templates = TPL.defend;
  else if (step === 'msg_agree')    templates = TPL.agree.map(t => tplFill(t, O.tplTarget));
  else if (step === 'msg_question') templates = TPL.question;
  else if (step === 'msg_pressure') templates = TPL.pressure;
  else if (step === 'msg_seer') {
    heading = `🔮 ${O.tplTarget} さんの占い結果を選んでください`;
    templates = [
      ...TPL.seer_wolf.map(t => tplFill(t, O.tplTarget)),
      ...TPL.seer_safe.map(t => tplFill(t, O.tplTarget)),
    ];
  } else if (step === 'msg_medium') {
    heading = `👁️ ${O.tplTarget} さんの霊媒結果を選んでください`;
    templates = [
      ...TPL.co_medium,
      ...TPL.medium_result_wolf.map(t => tplFill(t, O.tplTarget)),
      ...TPL.medium_result_safe.map(t => tplFill(t, O.tplTarget)),
    ];
  } else if (step === 'msg_doctor') {
    heading = '💊 騎士COの発言を選んでください';
    templates = TPL.co_doctor;
  } else if (step === 'msg_neko') {
    heading = '🐱 猫又COの発言を選んでください';
    templates = TPL.co_neko;
  }
  const btns = templates.map(t =>
    `<button class="tpl-btn tpl-send" data-msg="${esc(t)}">${t}</button>`
  ).join('');
  return `
    <div style="background:rgba(251,191,36,0.08); border:1px solid #fbbf2444; border-radius:12px; padding:1rem; margin-top:0.5rem;">
      <p style="color:#fbbf24; font-weight:700; font-size:0.9rem; margin-bottom:0.6rem;">${heading}</p>
      ${btns}

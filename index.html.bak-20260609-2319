    votes: {},               // {voterName: targetName}
    voteIdx: 0,
    voteResult: null,        // {executed, tally}
    winner: null,            // 'village' | 'wolf'
    log: [],
  };
}

// ========== HELPERS ==========
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function alive() { return S.players.filter(p => p.alive); }
function aliveByRole(r) { return S.players.filter(p => p.alive && p.role === r); }

function checkWin() {
  const a = alive();
  const wolves = a.filter(p => p.role === 'WEREWOLF').length;
  const others = a.length - wolves;
  if (wolves === 0) return 'village';
  if (wolves >= others) return 'wolf';
  return null;
}

function log(msg) { S.log.push(msg); }

function nightSteps() {
  const steps = [];
  // 霊媒師ステップ: 処刑があった場合のみ（夜の始めに霊媒師が結果を見る）
  if (S.lastExecuted && S.lastExecutedRole) {
    const mediums = aliveByRole('MEDIUM');
    if (mediums.length) steps.push({type:'medium', actor: mediums[0]});
  }
  // 占い師（毎夜）
  const seers = aliveByRole('SEER');
  if (seers.length) steps.push({type:'seer', actor: seers[0]});
  // 騎士・人狼（初日から行動可能）
  const docs = aliveByRole('DOCTOR');
  if (docs.length) steps.push({type:'doctor', actor: docs[0]});
  const wolves = aliveByRole('WEREWOLF');
  if (wolves.length) steps.push({type:'wolf', actors: wolves});
  return steps;
}

function mkSelect(id, players) {
  const opts = players.map(p => {
    const n = typeof p === 'string' ? p : (p.name || '');
    return `<option value="${esc(n)}">${esc(n)}</option>`;
  }).join('');
  return `<select id="${id}">${opts}</select>`;
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function val(id) { const e = document.getElementById(id); return e ? e.value : ''; }
function on(id, fn) { const e = document.getElementById(id); if (e) e.addEventListener('click', fn); }

// ========== RENDER HELPERS ==========

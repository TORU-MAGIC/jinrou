function renderOVote() {
  const myAlive = O.alive.some(p => p.name === O.playerName);

  // 死亡リスト（確定済み役職付き）
  const deadListHtml = O.deadPlayers.length ? `
    <details style="margin:.3rem 0 .5rem;">
      <summary style="color:#f87171;font-size:.78rem;font-weight:700;cursor:pointer;padding:.2rem 0;list-style:none;">
        ⚰️ 確定死亡者 (${O.deadPlayers.length}人) ▼
      </summary>
      <div class="death-list" style="margin-top:.3rem;">
        ${O.deadPlayers.map(d => {
          const causeLabel = d.cause==='人狼'?'🐺':d.cause==='猫又'?'🐱':'⚖️';
          return `<div class="death-entry">
            <span class="de-avatar">${d.avatar.emoji}</span>
            <span class="de-name">${esc(d.name)}</span>
            <span class="de-role" style="color:#475569;">❓ 役職不明</span>
            <span style="font-size:.7rem;color:#475569;">${causeLabel}</span>
          </div>`;
        }).join('')}
      </div>
    </details>` : '';

  if (O.voteSubmitted || !myAlive) {
    const pct = O.voteTotal > 0 ? Math.round(O.voteDone / O.voteTotal * 100) : 0;
    return `
      ${ph('🗳️',`第 ${O.day} 日 投票`,'集計中','#fbbf24')}
      ${deadListHtml}
      <div class="card" style="text-align:center;">
        <p style="color:#64748b; font-size:0.85rem; margin-bottom:0.5rem;">${O.voteSubmitted ? '✅ 投票しました！集計中...' : '観戦中'}</p>
        <div style="background:rgba(255,255,255,0.08); border-radius:8px; height:8px; overflow:hidden;">
          <div style="background:#6b21a8; height:100%; width:${pct}%; transition:width 0.4s;"></div>
        </div>
        <p style="color:#94a3b8; font-size:0.85rem; margin-top:0.5rem;">${O.voteDone} / ${O.voteTotal} 人が投票済み</p>
      </div>
    `;
  }
  const targets = O.alive.filter(p => p.name !== O.playerName);

  // アバター付き投票先グリッド（選択補助）
  const voteGrid = `
    <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin:.5rem 0 .8rem;">
      ${targets.map(p => {
        const av = getAvatar(p.name, O.players);
        const claim = O.roleClaims[p.name];
        const badge = claim ? `<span style="font-size:.6rem;color:#fbbf24;display:block;">${
          claim==='SEER'?'🔮?':claim==='DOCTOR'?'💊?':claim==='MEDIUM'?'👁️?':'🐱?'
        }</span>` : '';
        return `<button class="vote-avatar-btn" data-name="${esc(p.name)}"
          style="display:flex;flex-direction:column;align-items:center;min-width:68px;padding:.5rem .4rem;
                 background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:12px;
                 cursor:pointer;transition:background .15s;color:#e2e8f0;">
          <span style="font-size:2rem;line-height:1;">${av.emoji}</span>
          <span style="font-size:.75rem;font-weight:600;margin-top:.2rem;">${esc(p.name)}</span>
          ${(['solo','p2p','online'].includes(mode) && (O.notebook||{})[p.name]) ? `<span style="font-size:.58rem;display:block;color:${O.notebook[p.name]==='suspect'?'#f87171':'#4ade80'};">${O.notebook[p.name]==='suspect'?'🐺怪しい':'🤍信用'}</span>` : ''}
          ${badge}
        </button>`;
      }).join('')}
    </div>`;

  return `
    ${ph('🗳️',`第 ${O.day} 日 投票`,'誰を処刑しますか？','#fbbf24')}
    ${deadListHtml}
    <div class="card" style="padding:.8rem;">
      <p style="color:#fbbf24;font-size:.85rem;font-weight:700;margin:0 0 .4rem;">⚖️ 処刑する人を選んでください</p>
      <p style="color:#64748b;font-size:.75rem;margin:0 0 .5rem;">👆 アバターをタップすると自動選択されます</p>
      ${voteGrid}
      ${mkSelect('oVoteTgt', targets)}
      <button class="btn btn-primary" id="oVoteSend" style="margin-top:0.6rem;">🗳️　投票する</button>
    </div>
  `;
}

function renderOVoteResult() {
  const r = O.voteResult;
  if (!r) return '';
  const total = Object.values(r.tally).reduce((a,b)=>a+b,0);
  const bars = Object.entries(r.tally).sort(([,a],[,b])=>b-a).map(([n,c]) => {
    const pct = Math.round(c/total*16);
    const bar = '█'.repeat(pct)+'░'.repeat(16-pct);
    return `<div class="vote-bar ${n===r.executed?'executed':''}">${esc(n)}：${bar} ${c}票</div>`;
  }).join('');
  const nextBtn = O.winner
    ? `<button class="btn btn-primary" id="oGoGameOver">🏆　ゲーム結果を見る</button>`
    : (O.isHost ? `<button class="btn btn-night" id="oNextNight">🌙　夜に進む（ホスト）</button>`
                : `<div class="card" style="text-align:center;"><p style="color:#64748b; font-size:0.85rem;">ホストが次のフェーズへ進めます…</p></div>`);
  const nekHtml = r.nekomataVictim
    ? `<div style="margin-top:.8rem;padding:.6rem;background:rgba(251,146,60,.1);border:1px solid #fb923c44;border-radius:10px;color:#fb923c;font-size:.82rem;text-align:center;">
        🐱 猫又の道連れ: <strong>${esc(r.nekomataVictim)}</strong> も巻き込まれました！
       </div>` : '';
  return `
    ${ph('⚖️',`第${O.day}日 処刑結果`,'村人会議の結論が出ました','#f87171')}
    <div class="card"><p class="sec-label" style="margin-top:0;">📊 得票数</p>${bars}</div>
    <div class="vote-drama" style="text-align:center; padding:1.5rem; border-radius:16px;
         border:2px solid #ef4444; background:linear-gradient(135deg,#1a0505,#2d0a0a); margin:.6rem 0;">
      <p style="color:#f87171; font-size:.78rem; font-weight:700; letter-spacing:.12em; margin:0 0 .5rem;">⚖️ 処刑決定</p>
      <div style="font-size:3rem; line-height:1; margin:.4rem 0;">⚖️</div>
      <div style="font-size:2rem; font-weight:900; color:#fff; margin:.4rem 0;">${esc(r.executed)}</div>
      <div style="font-size:.88rem; color:#64748b; margin-bottom:.8rem;">役職は…ゲーム終了時に公開</div>
    </div>
    ${nekHtml}
    ${nextBtn}
  `;
}

function renderOGameOver() {
  if (['solo','p2p','online'].includes(mode) && O.gameRecap) return renderSoloRecap();
  const isV = O.winner === 'village';
  const color = isV ? '#4ade80' : '#f87171';
  const players = (O.finalPlayers && O.finalPlayers.length > 0)
    ? O.finalPlayers
    : (O.players || []).map(p => ({ name: p.name, role: undefined, alive: false }));
  const rows = players.map(p => {
    const info = ROLES[p.role] || {};
    return `<div class="player-row" style="border-left-color:${info.color||'#666'};">
      <span class="pr-icon">${info.icon||'❓'}</span>
      <span class="pr-name">${esc(p.name)}</span>
      <span class="pr-role" style="color:${info.color||'#aaa'};">${info.name||p.role||'不明'}</span>
      <span class="pr-status">${p.alive?'✅ 生存':'💀 死亡'}</span>
    </div>`;
  }).join('');
  const logHtml = O.log.length
    ? `<details style="margin-top:1rem;"><summary>📜 ゲームログ</summary>${O.log.map(e=>`<div class="log-entry">• ${esc(e)}</div>`).join('')}</details>` : '';
  return `
    ${ph(isV?'🎉':'🐺', isV?'村人チームの勝利！':'人狼チームの勝利！',
         isV?'人狼を全員倒しました！':'人狼が村を支配しました...', color)}
    <div class="card-colored" style="text-align:center; border:1px solid ${isV?'#22c55e':'#ef4444'}; background:${isV?'#22c55e':'#ef4444'}18; margin-bottom:1.2rem;">
      <p style="color:${color}; margin:0;">${isV?'村人チームの完全勝利！':'人狼の知略が勝りました...'}</p>
    </div>
    <p class="sec-label">📋 全員の役職</p>
    ${rows}${logHtml}
    <hr class="div">
    <button class="btn btn-primary" id="oRestart">🔄　もう一度</button>
  `;
}

